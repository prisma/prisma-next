types {
  Uuid = String @db.Uuid
}

namespace public {
  model Profile {
    id       Uuid   @id @default(uuid())
    username String
    owner_id String
    @@map("profile")
  }

  policy_select profile_owner_read {
    target = Profile
    roles  = [authenticated]
    using  = "owner_id::uuid = auth.uid()"
  }
}
