# Local Postgres TCP URL for the Hyperdrive binding "HYPERDRIVE".
# Wrangler reads this from .env (NOT .dev.vars) for local dev. See:
# https://developers.cloudflare.com/hyperdrive/configuration/local-development
#
# Bootstrap a local instance with `pnpm db:dev` (PGlite-backed `prisma dev`),
# copy this file to `.env` (gitignored), and paste the printed TCP URL.
WRANGLER_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgres://postgres:postgres@127.0.0.1:51214/template1?sslmode=disable"
