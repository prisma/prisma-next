# Copy to .env and set a Postgres connection string.
#
# For local development, any Postgres 14+ instance with the `vector` extension
# available works. Easiest path: `@prisma/dev` (see prisma-next-demo's README)
# or a Docker one-liner:
#
#   docker run --rm -d --name rsc-poc-pg -p 5432:5432 \
#     -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=rsc_poc \
#     pgvector/pgvector:pg17
#
# Then:
#
#   pnpm emit        # generate contract.json + contract.d.ts
#   pnpm db:init     # apply schema and marker
#   pnpm seed        # populate sample data
#   pnpm dev         # start Next.js
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rsc_poc
