{
  "extends": ["@prisma-next/tsconfig/base"],
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "app/**/*.ts", "app/**/*.tsx"],
  "exclude": ["dist", "test/fixtures/**/*"]
}
