{
  "name": "react-router-demo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "emit": "prisma-next contract emit",
    "emit:psl": "PRISMA_NEXT_CONTRACT_SOURCE=psl prisma-next contract emit",
    "emit:ts": "PRISMA_NEXT_CONTRACT_SOURCE=ts prisma-next contract emit",
    "db:init": "prisma-next db init",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@prisma-next/adapter-postgres": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/driver-postgres": "workspace:*",
    "@prisma-next/family-sql": "workspace:*",
    "@prisma-next/postgres": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-psl": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/target-postgres": "workspace:*",
    "@react-router/node": "^7.14.0",
    "@react-router/serve": "^7.14.0",
    "dotenv": "^16.4.5",
    "isbot": "^5.1.17",
    "pg": "catalog:",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.14.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/vite-plugin-contract-emit": "workspace:*",
    "@prisma/dev": "catalog:",
    "@react-router/dev": "^7.14.0",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "catalog:"
  }
}
