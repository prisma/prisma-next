{
  "name": "prisma-orm-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "emit": "prisma-next emit --contract prisma/contract.ts --out src/prisma-next --adapter ../../packages/adapter-postgres",
    "prisma-next:stamp": "tsx src/prisma-next/stamp-marker.ts",
    "seed": "tsx scripts/seed.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@prisma-next/compat-prisma": "workspace:*",
    "@prisma-next/runtime": "workspace:*",
    "@prisma-next/adapter-postgres": "workspace:*",
    "@prisma-next/driver-postgres": "workspace:*",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma/dev": "^0.1.1",
    "@types/node": "^20.16.5",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "prisma": "^6.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^1.6.0"
  }
}
