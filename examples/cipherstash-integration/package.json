    "@prisma-next/driver-postgres": "workspace:0.10.0",
    "@prisma-next/extension-cipherstash": "workspace:0.10.0",
    "@prisma-next/family-sql": "workspace:0.10.0",
    "@prisma-next/framework-components": "workspace:0.10.0",
    "@prisma-next/postgres": "workspace:0.10.0",
    "@prisma-next/sql-contract": "workspace:0.10.0",
    "@prisma-next/sql-contract-psl": "workspace:0.10.0",
    "@prisma-next/sql-orm-client": "workspace:0.10.0",
    "@prisma-next/sql-runtime": "workspace:0.10.0",
    "@prisma-next/target-postgres": "workspace:0.10.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:0.10.0",
    "@prisma-next/tsconfig": "workspace:0.10.0",
    "@types/node": "catalog:",
    "pathe": "^2.0.3",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
