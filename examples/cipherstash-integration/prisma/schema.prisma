// Cipherstash integration example schema.
//
// One model with one searchable encrypted column. The no-args form
// `cipherstash.EncryptedString()` defaults both `equality` and
// `freeTextSearch` to `true`, opting the column into both
// deterministic-equality and bloom-filter free-text search indexes
// (corresponding to the two cipherstash search operators the
// extension exposes: `cipherstashEq`, `cipherstashIlike`). Pass
// `{ equality: false }` / `{ freeTextSearch: false }` explicitly to
// opt out.

model User {
  id    String @id
  email cipherstash.EncryptedString()

  // The CipherStash EQL bundle (eql-2.2.1) hits a SQL-injection-style bug
  // in `eql_v2.add_encrypted_constraint` when the table name needs quoting
  // (reserved words, mixed case, etc.). `user` is reserved in Postgres,
  // so we map to `users` instead. Filed upstream — drop this comment +
  // `@@map` once the bundle is fixed and we re-vendor.
  @@map("users")
}
