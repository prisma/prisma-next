        "sql": "SELECT to_regclass('\"public\".\"users\"') IS NULL"
      }
    ],
    "execute": [
      {
        "description": "create table \"users\"",
        "sql": "CREATE TABLE \"public\".\"users\" (\n  \"accountId\" eql_v2_encrypted NOT NULL,\n  \"birthday\" eql_v2_encrypted NOT NULL,\n  \"email\" eql_v2_encrypted NOT NULL,\n  \"emailVerified\" eql_v2_encrypted NOT NULL,\n  \"id\" text NOT NULL,\n  \"preferences\" eql_v2_encrypted NOT NULL,\n  \"salary\" eql_v2_encrypted NOT NULL,\n  PRIMARY KEY (\"id\")\n)"
      }
    ],
    "postcheck": [
      {
        "description": "verify table \"users\" exists",
        "sql": "SELECT to_regclass('\"public\".\"users\"') IS NOT NULL"
      }
    ]
