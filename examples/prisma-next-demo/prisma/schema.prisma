types {
  Embedding1536 = Bytes @pgvector.column(length: 1536)
}

enum user_type {
  admin
  user
}

model User {
  id        String    @id @default(uuid())
  email     String
  createdAt DateTime  @default(now())
  kind      user_type
  posts     Post[]

  @@map("user")
}

model Post {
  id        String        @id @default(uuid())
  title     String
  userId    String
  createdAt DateTime      @default(now())
  embedding Embedding1536?

  user User @relation(fields: [userId], references: [id])

  @@map("post")
}

