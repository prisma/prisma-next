//
//
// --------------------------------------------------------------------------------------
// Account
// --------------------------------------------------------------------------------------
//
//

// todo Identity
model Account {
  // -----------
  // Boilerplate
  // -----------
  kind                              AccountModelKind                    @default(Account)
  id                                String                              @id @default(cuid())
  createdAt                         DateTime                            @default(now())
  updatedAt                         DateTime                            @updatedAt
  // -------
  // Domain
  // -------
  /// The provider that the user used to sign up.
  providerHandle                    AccountProviderHandle
  /// The mechanism the provider uses to provider credentials
  // TODO remove @default once we have migrated the schema once.
  providerType                      IdentityProviderType                @default(oauth)
  /// Typically an ID of the user in the provider's system. This should be the most reliable way to identify a
  /// user since it should not change, whilst everything else can (handle, email, etc.).
  userIdentifier                    String
  /// Primary email address for the identity.
  emailPrimary                      String
  /// Some providers allow users to have secondary emails on their profile. For example, GitHub.
  /// Note that to the extent made possible we do NOT store unverified emails. For example, GitHub
  /// exposes in its API which emails the user has are verified. Any email that is NOT verified would not be stored here.
  emailsSecondary                   String[]
  // ---
  // OAuth properties
  // ---
  /// A URL to the user's profile picture. This is useful for example to display the user's profile picture in the UI.
  // todo oauth_imageUrl
  imageUrl                          String?
  /// Some providers allow users to choose handles that are unique across all users in the provider's system.
  /// For example GitHub has this concept modelled on the "login" property of the user object. Some providers
  /// will not have this concept though, such as Google.
  // todo oauth_handle
  handle                            String?
  /// The access token that can be used to make requests to the provider's API on behalf of the user.
  // todo oauth_accessToken
  accessToken                       String?
  /// If null, this should mean that the access token never expires.
  /// Typically this information would be available from within the decoded access token. Keeping it here has some benefits, though:
  /// 1. Maybe there would be a case of a non-JWT access token? (TODO: is that actually possible in OAuth though?)
  /// 2. Use traditional SQL to operate on access tokens. E.g. no need for Postgres JSON SQL against decoded access tokens (which not all tools support, e.g. Prisma Client)
  ///    or reading access tokens into memory for filtering.
  // todo oauth_accessTokenExpires
  accessTokenExpires                DateTime?
  /// If null, this should mean that the access token never expires.
  /// This is not always present. For example, with GitHub OAuth login, the flow only provides this if the GitHub app has been configured to do
  /// so (see https://docs.github.com/en/apps/creating-github-apps/authenticating-with-a-github-app/refreshing-user-access-tokens#about-user-access-tokens-that-expire).
  // todo oauth_refreshToken
  refreshToken                      String?
  // ---
  // Email auth properties
  // ---
  email_passwordHash                String?
  // ---------
  // Back-Relations
  // ---------
  user                              User                                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                            String
  IdentityEmailPasswordResetRequest IdentityEmailPasswordResetRequest[]

  @@unique([providerHandle, userIdentifier])
  /// This constraint narrows the real-world domain to make our internal business rules easier to manage.
  /// Specifically, if a person
  /// - has two Github accounts, and
  /// - they sign up for one Prisma account for each Github account (so two users, internally), and
  /// - they change the primary email addresses associated with their Github accounts such that the first
  ///   account uses the primary email address from the second account, and
  /// - they sign in to Prisma using the first account,
  /// then there will be an error against this constraint, and the user would have to contact us to
  /// untangle their accounts. We've decided to not try to automatically resolve this edge case.
  ///
  /// See more discussion at https://github.com/prisma/pdp-control-plane/pull/1293#discussion_r1658074469
  // todo there's still a github user with two accounts set up with the same email address
  @@unique([providerHandle, emailPrimary])
}

// todo IdentityModelKind
enum AccountModelKind {
  Account
}

// todo IdentityProviderHandle
enum AccountProviderHandle {
  github
  google
  email
  vercel
}

enum IdentityProviderType {
  oauth
  email
}

