// VercelResource
// --------------------------------------------------------------------------------------

model VercelResource {
  // -----------
  // Boilerplate
  // -----------
  kind          VercelResourceModelKind @default(VercelResource)
  id            String                  @id @default(cuid())
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?
  // -------
  // Domain
  // -------
  productHandle String
  tenantId      String                  @unique
  name          String
  region        String

  // ---------
  // Back-Relations
  // ---------
  installation   IntegrationVercel @relation(fields: [installationId], references: [installationId], onDelete: Cascade)
  installationId String
  environment    Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  environmentId  String            @unique

  vercelResourceTransferRequests VercelResourceTransferRequest[]
  secretRotationRequests         VercelSecretRotationRequest[]

  @@index([installationId])
  @@index([tenantId])
  @@index([environmentId])
}

enum VercelResourceModelKind {
  VercelResource
}

model VercelResourceTransferRequest {
  id                   String                              @id
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt
  sourceInstallationId String
  sourceInstallation   IntegrationVercel                   @relation("SourceVercelResourceTransferRequests", fields: [sourceInstallationId], references: [installationId])
  targetInstallationId String?
  targetInstallation   IntegrationVercel?                  @relation("TargetVercelResourceTransferRequests", fields: [targetInstallationId], references: [installationId])
  status               VercelResourceTransferRequestStatus @default(pending)
  expiresAt            DateTime
  resources            VercelResource[]

  @@index([sourceInstallationId])
  @@index([targetInstallationId])
  @@index([status])
}

enum VercelResourceTransferRequestStatus {
  pending
  completed
  cancelled
}

// ----------------------------------------
// Vercel Secret Rotation
// ----------------------------------------
// Tracks pending secret rotation requests for delayed key deletion.
// When a user rotates secrets with delayOldSecretsExpirationHours > 0,
// we store the old key IDs here and a cron job deletes them later.

model VercelSecretRotationRequest {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  resourceId String
  resource   VercelResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  oldKeyIds         String[]
  scheduledDeleteAt DateTime

  status      VercelSecretRotationStatus @default(pending)
  completedAt DateTime?

  failedKeyIds     String[] @default([])
  deletionAttempts Int      @default(0)
  lastError        String?

  @@index([resourceId])
  @@index([status, scheduledDeleteAt])
}

enum VercelSecretRotationStatus {
  pending
  completed
  failed
}
