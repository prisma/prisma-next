//
//
// --------------------------------------------------------------------------------------
// PaymentMethodCard
// --------------------------------------------------------------------------------------
//
//

model PaymentMethodCard {
  // -----------
  // Boilerplate
  // -----------
  kind            PaymentMethodCardKind  @default(PaymentMethodCard)
  id              String                 @id @default(cuid())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  // -------
  // Domain
  // -------
  /// This strongly typed field is the parse result of stripeBrand. In case of "unknown"
  /// check the value of stripeBrand to see if it contains a new kind of value added into
  /// Stripe's API that needs to be added to our parsing logic.
  brand           PaymentMethodCardBrand
  stripeBrand     String
  last4           String
  expiryMonth     Int
  expiryYear      Int
  /// The Stripe API also adhears to this format.
  /// @see https://stripe.com/docs/api/cards/object#card_object-country
  billingCountry  CountryCodeISO3166
  billingName     String
  // ---------
  // Back-Relations
  // ---------
  paymentMethod   PaymentMethod          @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  paymentMethodId String                 @unique
}

enum PaymentMethodCardKind {
  PaymentMethodCard
}

/// These values are based on the Stripe API.
/// @see https://stripe.com/docs/api/cards/object#card_object-brand
enum PaymentMethodCardBrand {
  mastercard
  visa
  discover
  amex
  diners
  eftpos_au
  jcb
  unionpay
  unknown
}

//
//
// --------------------------------------------------------------------------------------
// Payment Method
// --------------------------------------------------------------------------------------
// This is basically a join table between Organization and PaymentMethodCard, or in graph terms,
// the edge between Organization and PaymentMethodCard. It allows defining a model per different kinds of
// payment mechanism (Credit Card, ...). It also affords a natural place to  annotate which one is the
// default one for the organization.
//

model PaymentMethod {
  // -----------
  // Boilerplate
  // -----------
  kind                  PaymentMethodKind  @default(PaymentMethod)
  id                    String             @id @default(cuid())
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  // -------
  // Domain
  // -------
  stripePaymentMethodId String             @unique
  isDefault             Boolean            @default(false)
  /// Signals the type of payment method which in turn indicates an invariant
  /// that the corresponding relation pointing to the record of this type is non-null.
  /// For example a value of "card" indicates that the "card" field
  /// relation should be non-null.
  type                  PaymentMethodType
  /// Should always be non-null if type is "card".
  card                  PaymentMethodCard?
  // ---------
  // Relations
  // ---------
  organization          Workspace          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId        String

  @@index([organizationId])
}

enum PaymentMethodType {
  card
}

enum PaymentMethodKind {
  PaymentMethod
}

//
//
// --------------------------------------------------------------------------------------
// Organization
// --------------------------------------------------------------------------------------
//
//

model Workspace {
  // -----------
  // Boilerplate
  // -----------
  kind              OrganizationModelKind    @default(Organization)
  id                String                   @id @default(cuid())
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  // -------
  // Domain
  // -------
  displayName       String
  stripeCustomerId  String?                  @unique
  billingEmail      String
  memberships       OrganizationMembership[]
  projects          Project[]
  holds             Hold[]
  /// Workspace should always have exactly one active PlanSubscription.
  /// The rest should be deleted PlanSubscriptions, the history of the
  /// workspace's plan subscriptions.
  planSubscriptions PlanSubscription[]
  preferences       Preferences[]
  paymentMethods    PaymentMethod[]
  actionLogs        ActionLog[]
  /// An optional physical address. This is useful for example
  /// to display on invoices sent to the organization.
  billingAddress    PhysicalAddress?
  // Workspace integrations
  integrations      WorkspaceIntegration[]
  integrationTokens IntegrationToken[]
  spendLimitCents   Int?

  /// Name of the integration of this workspace, For example: `Vercel`
  integrationName   String?
  /// Source where the integration was installed. For example: `marketplace`
  integrationSource String?
  /// Store Vercel-specific configuration
  integrationVercel IntegrationVercel?

  // OAuth back relations
  oauthClients   OAuthClient[]
  oauthTokens    OAuthToken[]             @relation("Workspace_Tokens")
  oauthAuthCodes OAuthAuthorizationCode[] @relation("Workspace_AuthCodes")

  @@map("Organization")
}

enum OrganizationModelKind {
  Organization
}

//
//
// --------------------------------------------------------------------------------------
// WorkspaceIntegration
// --------------------------------------------------------------------------------------
//
//
model WorkspaceIntegration {
  id                  String                 @id @default(cuid())
  serviceProviderName IntegrationService
  serviceProviderType IntegrationServiceType
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  workspaceId        String
  workspace          Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  configuration      Json?
  // WorkspaceIntegration can exists without integrationToken. This state represents an inactive integration
  integrationTokenId String?           @unique
  integrationToken   IntegrationToken? @relation(fields: [integrationTokenId], references: [id])

  @@index([workspaceId, serviceProviderName])
}

enum IntegrationServiceType {
  deploymentPlatform
  codespace
}

enum IntegrationService {
  netlify
  vercel
}

model PhysicalAddress {
  // -----------
  // Boilerplate
  // -----------
  kind            PhysicalAddressModelKind @default(PhysicalAddress)
  id              String                   @id @default(cuid())
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  // -------
  // Domain
  // -------
  country         CountryCodeISO3166?
  /// State, province, etc.
  region          String?
  city            String?
  /// Street, PO Box, company name, etc.
  addressLine1    String?
  /// Apartment, suite, unit, or building
  addressLine2    String?
  postalCodeOrZIP String?
  organization    Workspace                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String                   @unique
}

enum PhysicalAddressModelKind {
  PhysicalAddress
}

//
//
// --------------------------------------------------------------------------------------
// OrganizationMembership
// --------------------------------------------------------------------------------------
//
//

model OrganizationMembership {
  // -----------
  // Boilerplate
  // -----------
  kind                 OrganizationMembershipModelKind @default(OrganizationMembership)
  id                   String                          @id @default(cuid())
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt
  // -------
  // Domain
  // -------
  role                 OrganizationRole
  // ---------
  // Back-Relations
  // ---------
  user                 User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId               String
  /// OrganizationMembership will ALWAYS have an Organization.
  organization         Workspace?                      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId       String?
  workspacePreferences PreferencesUserWorkspace?

  @@unique([userId, organizationId])
  // we do multi-level joins sometimes where the user id is not involved
  @@index([organizationId])
}

enum OrganizationMembershipModelKind {
  OrganizationMembership
}

enum OrganizationRole {
  admin
  accountant
  developer
  viewer
}

//
//
// --------------------------------------------------------------------------------------
// Project
// --------------------------------------------------------------------------------------
//
//

model Project {
  // Boilerplate
  // -----------
  kind           ProjectModelKind @default(Project)
  id             String           @id @default(cuid())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  // -------
  // Domain
  // -------
  displayName    String
  theme          String?
  // ---------
  // Back-Relations
  // ---------
  environments   Environment[]
  /// Project will ALWAYS have an Organization.
  organization   Workspace?       @relation(fields: [organizationId], references: [id])
  organizationId String?
  actionLogs     ActionLog[]

  @@index([organizationId])
}

enum ProjectModelKind {
  Project
}

//
//
// --------------------------------------------------------------------------------------
// Environment
// --------------------------------------------------------------------------------------
//
//

model Environment {
  // -----------
  // Boilerplate
  // -----------
  kind                 EnvironmentModelKind @default(Environment)
  id                   String               @id @default(cuid())
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  // -------
  // Domain
  // -------
  displayName          String
  /// This value is only available for PPg environments (`allowRemoteDatabases` is `false`).
  ///
  /// Reason for the `display` prefix:
  /// This is the value that the user selects on the UI when they create a new PPg environment.
  /// This might be different from the region stored in Tenant Manager because there is a region
  /// mapping happens on tenant creation.
  displayPpgRegionId   String?
  isDefault            Boolean
  serviceKeys          ServiceKey[]
  databaseLinks        DatabaseLink[]
  tenantId             String               @unique
  /// - true if products in the environment may connect to external, user-controlled databases
  /// - false for PPg environments
  allowRemoteDatabases Boolean              @default(true)
  /// the current status of environment provisioning
  /// - 'ready' when an environment is ready to be used (most environments, most of the time)
  /// - the status of a ppg provisioning process
  /// - the status of a ppg migration process
  ///
  /// see core:types:EnvironmentProvisionStatus (it's not an enum yet because migrating enums in
  /// Postgres with Prisma is flaky, and these values will change)
  provisionStatus      String               @default("ready")
  // ---------
  // Back-Relations
  // ---------
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId            String
  actionLogs           ActionLog[]
  vercelResource       VercelResource?
  /// Holds are at the scope of a worksapce however some kinds of holds can specify specific environments they apply to.
  /// This contains a list of any such holds.
  hold                 Hold?                @relation(fields: [holdId], references: [id])
  holdId               String?

  @@index([projectId])
}

enum EnvironmentModelKind {
  Environment
}

//
//
// --------------------------------------------------------------------------------------
// ServiceKey
// --------------------------------------------------------------------------------------
//
//

model ServiceKey {
  // -----------
  // Boilerplate
  // -----------
  kind           ServiceKeyModelKind @default(ServiceKey)
  id             String              @id @default(cuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  // -------
  // Domain
