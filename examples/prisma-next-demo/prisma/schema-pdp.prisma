// Change for production incident on 09-03-2025
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
  output          = "../node_modules/prisma-client"
}

generator client_qc {
  provider        = "prisma-client"
  previewFeatures = ["relationJoins"]
  output          = "./generated"
  engineType      = "client"
  runtime         = "cloudflare"
}

datasource db {
  provider  = "postgres"
  url       = env("DATABASE_URL_ACCELERATE")
  directUrl = env("DATABASE_URL_DIRECT")
}

//
//
// --------------------------------------------------------------------------------------
// User
// --------------------------------------------------------------------------------------
//
//

model User {
  // -----------
  // Boilerplate
  // -----------
  kind                              UserModelKind                     @default(User)
  id                                String                            @id @default(cuid())
  createdAt                         DateTime                          @default(now())
  updatedAt                         DateTime                          @updatedAt
  // -------
  // Domain
  // -------
  deactivated                       Boolean?
  deactivatedAt                     DateTime?
  displayName                       String?
  email                             String                            @unique
  image                             String?
  toltReferralId                    String?                           @unique
  // The ID of the Tolt Affiliate user that referred this user.
  //  bNot used by our codebase. Utilized by the data team for mapping purposes.
  toltReferredByAffiliateId         String?
  experimentalFeatureAccessPolicies ExperimentalFeatureAccessPolicy[]
  sessions                          Session[]
  // ---------
  // Back-Relations
  // ---------
  accounts                          Account[]
  organizationMemberships           OrganizationMembership[]
  preferences                       Preferences?
  actionLogs                        ActionLog[]
  notifications                     Notification[]
  managementTokens                  ManagementToken[]
  signatures                        MachineSignature[]
  attributedPlanSubscriptions       PlanSubscription[]
  workspacePreferences              PreferencesUserWorkspace[]
  oauthTokens                       OAuthToken[]                      @relation("User_Tokens")
  oauthAuthCodes                    OAuthAuthorizationCode[]          @relation("User_AuthCodes")

  @@index([id, createdAt])
  @@index([createdAt, id])
  @@index([createdAt])
}

enum UserModelKind {
  User
}

//
//
// --------------------------------------------------------------------------------------
// Management Token
// --------------------------------------------------------------------------------------
//
//

model ManagementToken {
  // -----------
  // Boilerplate
  // -----------
  kind        ManagementTokenModelKind @default(ManagementToken)
  id          String                   @id @default(cuid())
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  // -------
  // Domain
  // -------
  hash        String                   @unique()
  valueHint   String
  displayName String
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
}

enum ManagementTokenModelKind {
  ManagementToken
}

//
//
// --------------------------------------------------------------------------------------
// Integration Token
// --------------------------------------------------------------------------------------
//
//

model IntegrationToken {
  // -----------
  // Boilerplate
  // -----------
  kind                 IntegrationTokenModelKind @default(IntegrationToken)
  id                   String                    @id @default(cuid())
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  // -------
  // Domain
  // -------
  hash                 String                    @unique()
  valueHint            String
  displayName          String
  // -------
  // Back relations
  // -------
  workspaceId          String
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceIntegration WorkspaceIntegration?

  @@index([workspaceId])
}

enum IntegrationTokenModelKind {
  IntegrationToken
}

//
//
// --------------------------------------------------------------------------------------
// Sessions
// --------------------------------------------------------------------------------------
//
//

model Session {
  // -----------
  // Boilerplate
  // -----------
  kind                       SessionModelKind      @default(Session)
  id                         String                @id @default(cuid())
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  // -------
  // Domain
  // -------
  expiresAt                  DateTime
  user                       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                     String
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-browser.html
  browserHandle              BrowserHandle         @default(unknown)
  browserHandleOther         String?
  browserVersion             String?
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-os.html#name-string
  operatingSystemHandle      operatingSystemHandle @default(unknown)
  operatingSystemHandleOther String?
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-os.html#version-string
  operatingSystemVersion     String?
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-device.html#type-string
  deviceTypeHandle           DeviceTypeHandle      @default(unknown)
  deviceTypeHandleOther      String?
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-device.html#model-string
  deviceModel                String?
  /// See https://docs.uaparser.js.org/v2/api/ua-parser-js/get-device.html#vendor-string
  deviceVendorHandle         DeviceVendorHandle    @default(unknown)
  deviceVendorHandleOther    String?

  @@index([userId])
}

model OAuthClient {
  id                 String                   @id @default(cuid())
  name               String
  description        String?
  redirectUris       String[]
  clientSecretHash   String
  clientSecretHint   String                   @default("")
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  //  ---------
  //  Back-Relations
  //  ---------
  workspaceId        String
  workspace          Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  authorizationCodes OAuthAuthorizationCode[] @relation("OAuthClient_AuthCodes")
  tokens             OAuthToken[]             @relation("OAuthClient_Tokens")
}

model OAuthAuthorizationCode {
  id                  String              @id @default(cuid())
  code                String              @unique
  redirectUri         String
  scopes              String[]
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime            @default(now())
  // PKCE fields
  codeChallenge       String?
  codeChallengeMethod CodeChallengeMethod @default(S256)
  //  ---------
  //  Back-Relations
  //  ---------
  client              OAuthClient         @relation("OAuthClient_AuthCodes", fields: [clientId], references: [id], onDelete: Cascade)
  clientId            String
  user                User                @relation("User_AuthCodes", fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  workspace           Workspace           @relation("Workspace_AuthCodes", fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId         String
}

enum CodeChallengeMethod {
  plain
  S256
}

model OAuthToken {
  id                    String      @id @default(cuid())
  // ---------
  // Tokens
  // ---------
  // Remark: access token does not need to be hashed when refresh tokens are implemented. Reason: access tokens are short lived
  accessTokenHash       String      @unique
  // Will be used for short lived access tokens (no need for hashing). TODO: This will be implemented together withh refresh tokens
  accessToken           String?     @unique // Optional for future use
  refreshTokenHash      String?     @unique
  // ---------
  // Expiration
  // ---------
  accessTokenExpiresAt  DateTime
  // When the refresh token is used `refreshTokenExpiresAt` will be set to the same time as `refreshTokenUsedAt`
  refreshTokenExpiresAt DateTime?
  // ---------
  // Metadata
  // ---------
  scopes                String[]
  createdAt             DateTime    @default(now())
  refreshTokenUsedAt    DateTime?
  // ---------
  // Back-Relations
  // ---------
  client                OAuthClient @relation("OAuthClient_Tokens", fields: [clientId], references: [id], onDelete: Cascade)
  clientId              String
  createdByUser         User        @relation("User_Tokens", fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdByUserId       String
  workspace             Workspace   @relation("Workspace_Tokens", fields: [workspaceId], references: [id], onDelete: Cascade)
  workspaceId           String
}

enum operatingSystemHandle {
  windows
  macos
  linux
  ios
  android
  ubuntu
  other
  unknown
}

enum BrowserHandle {
  chrome
  firefox
  safari
  edge
  opera
  other
  unknown
}

enum DeviceVendorHandle {
  apple
  samsung
  microsoft
  amazon
  acer
  lenovo
  google
  other
  unknown
}

enum DeviceTypeHandle {
  desktop
  tablet
  mobile
  smarttv
  console
  wearable
  embedded
  unknown
}

enum SessionModelKind {
  Session
}

//
//
// --------------------------------------------------------------------------------------
// Preferences
// --------------------------------------------------------------------------------------
//
//

model Preferences {
  // -----------
  // Boilerplate
  // -----------
  kind                  PreferencesKind @default(PreferencesKind)
  id                    String          @id @default(cuid())
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  // -------
  // Domain
  // -------
  /// defaultOrganization is optional because a user might have had default org set to an another users org, which the other user might choose to delete.
  defaultOrganization   Workspace?      @relation(fields: [defaultOrganizationId], references: [id])
  defaultOrganizationId String?

  // ---------
  // Back-Relations
  // ---------
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  @@index([userId])
}

enum PreferencesKind {
  // TODO rename to "Preferences"
  PreferencesKind
}

model PreferencesUserWorkspace {
  // -----------
  // Boilerplate
  // -----------
  kind          PreferencesUserWorkspaceKind @default(PreferencesUserWorkspace)
  id            String                       @id @default(cuid())
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  // -----------
  // Domain
  // -----------
  notifications NotificationSettings[]

  // ---------
  // Back-Relations
  // ---------
  // This relation enables a cascade delete of the PreferencesUserWorkspace record when the OrganizationMembership record is deleted.
  workspaceMembership OrganizationMembership @relation(fields: [userId, workspaceId], references: [userId, organizationId], onDelete: Cascade)
  workspaceId         String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([userId, workspaceId])
  @@index([userId])
}

enum PreferencesUserWorkspaceKind {
  PreferencesUserWorkspace
}

