      }
    ],
    "execute": [
      {
        "description": "drop column \"avatarUrl\"",
        "sql": "ALTER TABLE \"public\".\"user\" DROP COLUMN \"avatarUrl\""
      }
    ],
    "postcheck": [
      {
        "description": "verify column \"avatarUrl\" is removed",
        "sql": "SELECT NOT EXISTS (\n  SELECT 1\n  FROM information_schema.columns\n  WHERE table_schema = 'public'\n    AND table_name = 'user'\n    AND column_name = 'avatarUrl'\n)"
      }
    ]
