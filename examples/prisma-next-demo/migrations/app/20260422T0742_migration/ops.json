[
  {
    "id": "column.public.user.displayName",
    "label": "Add column \"displayName\" to \"user\"",
    "operationClass": "additive",
    "target": {
      "id": "postgres",
      "details": {
        "schema": "public",
        "objectType": "column",
        "name": "displayName",
        "table": "user"
      }
    },
    "precheck": [
      {
        "description": "ensure column \"displayName\" is missing",
        "sql": "SELECT NOT EXISTS (SELECT 1 AS \"one\" FROM \"information_schema\".\"columns\" WHERE (\"table_schema\" = $1 AND \"table_name\" = $2 AND \"column_name\" = $3)) AS \"result\"",
        "params": ["public", "user", "displayName"]
      }
    ],
    "execute": [
      {
        "description": "add column \"displayName\"",
        "sql": "ALTER TABLE \"public\".\"user\" ADD COLUMN \"displayName\" text"
      }
    ],
    "postcheck": [
      {
        "description": "verify column \"displayName\" exists",
        "sql": "SELECT EXISTS (SELECT 1 AS \"one\" FROM \"information_schema\".\"columns\" WHERE (\"table_schema\" = $1 AND \"table_name\" = $2 AND \"column_name\" = $3)) AS \"result\"",
        "params": ["public", "user", "displayName"]
      }
    ]
  }
]
