  {
    "id": "foreignKey.post.post_userId_fkey",
    "label": "Add foreign key \"post_userId_fkey\" on \"post\"",
    "operationClass": "additive",
    "target": {
      "id": "postgres",
      "details": {
        "schema": "public",
        "objectType": "foreignKey",
        "name": "post_userId_fkey",
        "table": "post"
      }
    },
    "precheck": [
      {
        "description": "ensure FK \"post_userId_fkey\" does not exist",
        "sql": "SELECT NOT EXISTS (\n  SELECT 1 FROM pg_constraint c\n  JOIN pg_namespace n ON c.connamespace = n.oid\n  WHERE c.conname = 'post_userId_fkey'\n  AND n.nspname = 'public'\n  AND c.conrelid = to_regclass('\"public\".\"post\"')\n)"
      }
    ],
    "execute": [
      {
        "description": "add FK \"post_userId_fkey\"",
        "sql": "ALTER TABLE \"public\".\"post\"\nADD CONSTRAINT \"post_userId_fkey\"\nFOREIGN KEY (\"userId\")\nREFERENCES \"public\".\"user\" (\"id\")"
      }
    ],
    "postcheck": [
      {
        "description": "verify FK \"post_userId_fkey\" exists",
        "sql": "SELECT EXISTS (\n  SELECT 1 FROM pg_constraint c\n  JOIN pg_namespace n ON c.connamespace = n.oid\n  WHERE c.conname = 'post_userId_fkey'\n  AND n.nspname = 'public'\n  AND c.conrelid = to_regclass('\"public\".\"post\"')\n)"
      }
    ]
  },
