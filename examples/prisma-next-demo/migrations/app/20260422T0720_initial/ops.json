  {
    "id": "foreignKey.post.post_userId_fkey",
    "label": "Add foreign key \"post_userId_fkey\" on \"post\"",
    "operationClass": "additive",
    "target": {
      "id": "postgres",
      "details": {
        "schema": "public",
        "objectType": "foreignKey",
        "name": "post_userId_fkey",
        "table": "post"
      }
    },
    "precheck": [
      {
        "description": "ensure FK \"post_userId_fkey\" does not exist",
        "sql": "SELECT NOT EXISTS (SELECT 1 AS \"one\" FROM \"pg_constraint\" AS \"c\" INNER JOIN \"pg_namespace\" AS \"n\" ON \"n\".\"oid\" = \"c\".\"connamespace\" WHERE (\"c\".\"conname\" = $1 AND \"n\".\"nspname\" = $2 AND \"c\".\"conrelid\" = to_regclass($3))) AS \"result\"",
        "params": ["post_userId_fkey", "public", "\"public\".\"post\""]
      }
    ],
    "execute": [
      {
        "description": "add FK \"post_userId_fkey\"",
        "sql": "ALTER TABLE \"public\".\"post\"\nADD CONSTRAINT \"post_userId_fkey\"\nFOREIGN KEY (\"userId\")\nREFERENCES \"public\".\"user\" (\"id\")"
      }
    ],
    "postcheck": [
      {
        "description": "verify FK \"post_userId_fkey\" exists",
        "sql": "SELECT EXISTS (SELECT 1 AS \"one\" FROM \"pg_constraint\" AS \"c\" INNER JOIN \"pg_namespace\" AS \"n\" ON \"n\".\"oid\" = \"c\".\"connamespace\" WHERE (\"c\".\"conname\" = $1 AND \"n\".\"nspname\" = $2 AND \"c\".\"conrelid\" = to_regclass($3))) AS \"result\"",
        "params": ["post_userId_fkey", "public", "\"public\".\"post\""]
      }
    ]
  },
