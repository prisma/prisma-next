{
  "name": "@prisma-next/example-workflow-customer-onboarding",
  "private": true,
  "type": "module",
  "version": "0.13.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "workflow:generate": "prisma-next workflow generate --schema src/schema.prisma --studio studio/workflows.html --svg studio/onboarding-risk-review.svg",
    "workflow:test": "prisma-next workflow test --schema src/schema.prisma --payload fixtures/account-created.json --json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "biome check . --error-on-warnings"
  },
  "dependencies": {
    "@prisma-next/workflows": "workspace:0.13.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:0.13.0",
    "@prisma-next/tsconfig": "workspace:0.13.0",
    "@types/node": "catalog:",
    "@prisma/dev": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
