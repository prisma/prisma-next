[
  {
    "id": "collection.users.setValidation",
    "label": "Set validation on users",
    "operationClass": "destructive",
    "precheck": [],
    "execute": [
      {
        "description": "set validation on users",
        "command": {
          "kind": "collMod",
          "collection": "users",
          "validator": {
            "$jsonSchema": {
              "additionalProperties": false,
              "bsonType": "object",
              "properties": {
                "_id": {
                  "bsonType": "objectId"
                },
                "address": {
                  "oneOf": [
                    {
                      "bsonType": "null"
                    },
                    {
                      "additionalProperties": false,
                      "bsonType": "object",
                      "properties": {
                        "city": {
                          "bsonType": "string"
                        },
                        "country": {
                          "bsonType": "string"
                        },
                        "street": {
                          "bsonType": "string"
                        },
                        "zip": {
                          "bsonType": ["null", "string"]
                        }
                      },
                      "required": ["city", "country", "street"]
                    }
                  ]
                },
                "bio": {
                  "bsonType": ["null", "string"]
                },
                "email": {
                  "bsonType": "string"
                },
                "name": {
                  "bsonType": "string"
                },
                "role": {
                  "bsonType": "string",
                  "enum": ["admin", "author", "reader"]
                }
              },
              "required": ["_id", "email", "name", "role"]
            }
          },
          "validationLevel": "strict",
          "validationAction": "error"
        }
      }
    ],
    "postcheck": []
  }
]
