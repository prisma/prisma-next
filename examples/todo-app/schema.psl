model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  active    Boolean    @default(true)
  bio       String?
  createdAt DateTime   @default(now())

  posts     Post[]
}

model Post {
  id        Int        @id @default(autoincrement())
  title     String
  published Boolean    @default(false)
  createdAt DateTime   @default(now())

  user      User
}

