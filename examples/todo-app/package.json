{
  "name": "todo-app",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "pnpm exec node dist/main.js",
    "generate": "pnpm exec prisma-next generate schema.psl",
    "migrate": "pnpm exec node dist/migrate.js",
    "reset-db": "pnpm exec node dist/reset-db.js",
    "generate-migration": "pnpm exec node dist/generate-migration.js",
    "evolve-schema": "pnpm exec node dist/evolve-schema.js",
    "demo": "pnpm exec node dist/demo.js",
    "test-planner": "pnpm exec node dist/test-planner.js",
    "test:migration": "pnpm reset-db && pnpm migrate",
    "test:migration-twice": "pnpm reset-db && pnpm migrate && pnpm migrate",
    "test:planner": "pnpm reset-db && pnpm evolve-schema && pnpm migrate",
    "clean": "rm -rf dist .prisma",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "pnpm exec tsc --noEmit && pnpm exec tsc --noEmit --skipLibCheck $(find src -name '*.ts' 2>/dev/null || true)"
  },
  "dependencies": {
    "@prisma/cli": "workspace:*",
    "@prisma/dev": "^0.11.0",
    "@prisma/migrate": "workspace:*",
    "@prisma/orm": "workspace:*",
    "@prisma/psl": "workspace:*",
    "@prisma/relational-ir": "workspace:*",
    "@prisma/runtime": "workspace:*",
    "@prisma/schema-emitter": "workspace:*",
    "@prisma/sql": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
