# supabase-todos environment configuration
#
# Copy to `.env` (gitignored) and fill in. Defaults below match the local
# Supabase stack started by `supabase start` from this directory.

# Direct (non-pooled) Postgres URL. Used by `migrate:up` and the seed
# script. The `postgres` superuser bypasses RLS — required for
# `ALTER TABLE ... ENABLE ROW LEVEL SECURITY` and admin seeding.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase API URL exposed by `supabase start` (PostgREST + Auth).
SUPABASE_URL=http://127.0.0.1:54321

# Service-role secret key from `supabase status`. Bypasses RLS; use only
# in admin scripts (seed, migrations) and never from request handlers.
# These local-stack keys are deterministically derived from the local
# Supabase config and are NOT secrets in real deployments — replace
# with the real values for any non-local environment.
SUPABASE_SERVICE_ROLE_KEY=replace-me-from-supabase-status-output

# Anon (publishable) key. Used by the in-browser supabase-js client and
# any per-request runtime that scopes to a JWT.
SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Vite-exposed copies of the public Supabase URL + anon key. Vite only
# bundles env vars whose names start with `VITE_` into the client; the
# JWT secret and service-role key MUST NOT be `VITE_`-prefixed (they
# would leak to the browser). Set these to the same values as
# SUPABASE_URL / SUPABASE_ANON_KEY above. The SPA reads them at boot
# from import.meta.env.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Shared HS256 secret the local Supabase stack signs JWTs with. The Hono
# JWT-verification middleware (`src/server/middleware/jwt.ts`, T4.2) uses
# it to verify `Authorization: Bearer <token>`. Read from
# `supabase status -o env` (the `JWT_SECRET=...` line). The value below
# is the well-known local-dev secret; it is NOT a real secret in any
# deployed environment — replace before going anywhere near production.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
