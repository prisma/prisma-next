{
  "name": "@prisma-next/target-sqlite",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/errors": "workspace:*",
    "@prisma-next/family-sql": "workspace:*",
    "@prisma-next/framework-components": "workspace:*",
    "@prisma-next/migration-tools": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-errors": "workspace:*",
    "@prisma-next/sql-relational-core": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/sql-schema-ir": "workspace:*",
    "@prisma-next/ts-render": "workspace:*",
    "@prisma-next/utils": "workspace:*"
  },
  "devDependencies": {
    "@prisma-next/driver-sqlite": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./codec-ids": "./dist/codec-ids.mjs",
    "./codec-types": "./dist/codec-types.mjs",
    "./codecs": "./dist/codecs.mjs",
    "./control": "./dist/control.mjs",
    "./default-normalizer": "./dist/default-normalizer.mjs",
    "./migration": "./dist/migration.mjs",
    "./native-type-normalizer": "./dist/native-type-normalizer.mjs",
    "./op-factory-call": "./dist/op-factory-call.mjs",
    "./pack": "./dist/pack.mjs",
    "./planner": "./dist/planner.mjs",
    "./planner-produced-sqlite-migration": "./dist/planner-produced-sqlite-migration.mjs",
    "./planner-target-details": "./dist/planner-target-details.mjs",
    "./render-ops": "./dist/render-ops.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./sql-utils": "./dist/sql-utils.mjs",
    "./statement-builders": "./dist/statement-builders.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-targets/3-targets/sqlite"
  }
}
