{
  "name": "@prisma-next/core-control-plane",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Control plane domain actions, config types, validation, and error factories for Prisma Next",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../biome.json --error-on-warnings",
    "clean": "node ../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "arktype": "^2.1.26"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./config-types": {
      "types": "./dist/exports/config-types.d.ts",
      "import": "./dist/exports/config-types.js"
    },
    "./config-validation": {
      "types": "./dist/exports/config-validation.d.ts",
      "import": "./dist/exports/config-validation.js"
    },
    "./emit-contract": {
      "types": "./dist/exports/emit-contract.d.ts",
      "import": "./dist/exports/emit-contract.js"
    },
    "./verify-database": {
      "types": "./dist/exports/verify-database.d.ts",
      "import": "./dist/exports/verify-database.js"
    },
    "./errors": {
      "types": "./dist/exports/errors.d.ts",
      "import": "./dist/exports/errors.js"
    },
    "./pack-manifest-types": {
      "types": "./dist/exports/pack-manifest-types.d.ts",
      "import": "./dist/exports/pack-manifest-types.js"
    },
    "./utils/marker-parser": {
      "types": "./dist/exports/marker-parser.d.ts",
      "import": "./dist/exports/marker-parser.js"
    }
  }
}
