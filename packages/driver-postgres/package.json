{
  "name": "@prisma-next/driver-postgres",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma-next/sql-target": "workspace:*",
    "pg": "^8.11.5",
    "pg-cursor": "^2.10.5"
  },
  "devDependencies": {
    "pg-mem": "^3.0.5",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1",
    "@types/pg": "^8.11.10",
    "@types/pg-cursor": "^2.4.6"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    }
  }
}
