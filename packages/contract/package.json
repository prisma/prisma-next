{
  "name": "@prisma-next/contract",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Data contract type definitions and JSON schema for Prisma Next",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --config ../../eslint.config.mjs --ext .ts,.tsx --ignore-pattern dist --ignore-pattern coverage --max-warnings 0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "exports": {
    "./types": {
      "types": "./dist/exports/types.d.ts",
      "import": "./dist/exports/types.js"
    },
    "./schema-document": "./schemas/data-contract-document-v1.json"
  }
}
