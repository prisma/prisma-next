{
  "name": "@prisma-next/driver-postgres",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../biome.json --error-on-warnings",
    "clean": "node ../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/control-plane": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "arktype": "^2.0.0",
    "pg": "^8.11.5",
    "pg-cursor": "^2.10.5"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "pg-mem": "^3.0.5",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1",
    "@types/pg": "^8.11.10",
    "@types/pg-cursor": "^2.4.6"
  },
  "exports": {
    "./cli": {
      "types": "./dist/exports/cli.d.ts",
      "import": "./dist/exports/cli.js"
    },
    "./runtime": {
      "types": "./dist/exports/runtime.d.ts",
      "import": "./dist/exports/runtime.js"
    }
  }
}
