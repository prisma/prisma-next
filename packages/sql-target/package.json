  "dependencies": {
    "@prisma-next/emitter": "workspace:*"
  },
  "devDependencies": {
    "ts-toolbelt": "^9.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    }
  }
