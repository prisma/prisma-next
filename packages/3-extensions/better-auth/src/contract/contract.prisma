// use prisma-next

// BetterAuth core schema (https://www.better-auth.com/docs/concepts/database#core-schema):
// models User / Session / Account / Verification over the ecosystem-default
// singular table names in the `public` namespace. Ids are text — BetterAuth
// generates string IDs. Control policy is managed (contract default): the
// framework owns these tables' DDL via the space's shipped migrations.

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Backrelations are named after BetterAuth's model names (singular) so the
  // adapter's native join path lands joined rows under the keys BetterAuth
  // expects (`join: { session: true }` → row.session).
  session Session[]
  account Account[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id])

  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id])

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime

  @@map("verification")
}
