{
  "name": "@prisma-next/adapter-postgres",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint . --config ../../eslint.config.mjs --ext .ts,.tsx --ignore-pattern dist --ignore-pattern coverage"
  },
  "dependencies": {
    "@prisma-next/sql-query": "workspace:*",
    "@prisma-next/sql-target": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "exports": {
    "./adapter": {
      "types": "./dist/exports/adapter.d.ts",
      "import": "./dist/exports/adapter.js"
    },
    "./types": {
      "types": "./dist/exports/types.d.ts",
      "import": "./dist/exports/types.js"
    },
    "./codec-types": {
      "types": "./dist/exports/codec-types.d.ts",
      "import": "./dist/exports/codec-types.js"
    }
  }
}
