{
  "name": "@prisma-next/sql-query",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../biome.json --error-on-warnings",
    "clean": "node ../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/sql-target": "workspace:*",
    "arktype": "^2.1.25"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "ts-toolbelt": "^9.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "exports": {
    "./sql": {
      "types": "./dist/exports/sql.d.ts",
      "import": "./dist/exports/sql.js"
    },
    "./schema": {
      "types": "./dist/exports/schema.d.ts",
      "import": "./dist/exports/schema.js"
    },
    "./param": {
      "types": "./dist/exports/param.d.ts",
      "import": "./dist/exports/param.js"
    },
    "./types": {
      "types": "./dist/exports/types.d.ts",
      "import": "./dist/exports/types.js"
    },
    "./errors": {
      "types": "./dist/exports/errors.d.ts",
      "import": "./dist/exports/errors.js"
    },
    "./contract-builder": {
      "types": "./dist/exports/contract-builder.d.ts",
      "import": "./dist/exports/contract-builder.js"
    },
    "./schema-sql": "./schemas/data-contract-sql-v1.json"
  }
}
