{
  "name": "@prisma-next/e2e-tests",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../biome.json --error-on-warnings",
    "emit": "prisma-next emit --contract test/fixtures/contract.ts --out test/fixtures/generated --adapter ../../packages/adapter-postgres",
    "clean": "node ../../scripts/clean.mjs"
  },
  "devDependencies": {
    "vitest": "^2.1.1",
    "typescript": "^5.9.3",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.10",
    "pg": "^8.11.5"
  },
  "dependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/sql-query": "workspace:*",
    "@prisma-next/sql-target": "workspace:*",
    "@prisma-next/adapter-postgres": "workspace:*",
    "@prisma-next/driver-postgres": "workspace:*",
    "@prisma-next/test-utils": "workspace:*"
  }
}
