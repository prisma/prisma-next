{
  "name": "@prisma-next/core-control-plane",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "description": "Control plane domain actions, config types, validation, and error factories for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.1.26",
    "prettier": "^3.3.3"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./config-types": "./src/exports/config-types.ts",
    "./config-validation": "./src/exports/config-validation.ts",
    "./emission": "./src/exports/emission.ts",
    "./errors": "./src/exports/errors.ts",
    "./schema-view": "./src/exports/schema-view.ts",
    "./stack": "./src/exports/stack.ts",
    "./types": "./src/exports/types.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./config-types": "./dist/config-types.mjs",
      "./config-validation": "./dist/config-validation.mjs",
      "./emission": "./dist/emission.mjs",
      "./errors": "./dist/errors.mjs",
      "./schema-view": "./dist/schema-view.mjs",
      "./stack": "./dist/stack.mjs",
      "./types": "./dist/types.mjs",
      "./package.json": "./package.json"
    }
  }
}
