{
  "name": "@prisma-next/psl-types",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Shared PSL AST type definitions for parser and printer",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/0-foundation/psl-types"
  }
}
