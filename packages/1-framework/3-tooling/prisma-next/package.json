{
  "name": "prisma-next",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Prisma Next CLI: emit, verify, sign, and migrate databases from a type-safe contract.",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "lint": "node ./scripts/lint-sync.mjs",
    "clean": "rm -rf dist"
  },
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@dagrejs/dagre": "^3.0.0",
    "@prisma-next/config": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/errors": "workspace:*",
    "@prisma-next/framework-components": "workspace:*",
    "@prisma-next/migration-tools": "workspace:*",
    "@prisma-next/psl-printer": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0",
    "c12": "^3.3.2",
    "closest-match": "^1.3.3",
    "colorette": "^2.0.20",
    "commander": "^12.0.0",
    "esbuild": "^0.25.11",
    "package-manager-detector": "^1.6.0",
    "pathe": "^2.0.3",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.1.2",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.mts",
      "import": "./dist/exports/index.mjs"
    },
    "./config-types": {
      "types": "./dist/exports/config-types.d.mts",
      "import": "./dist/exports/config-types.mjs"
    },
    "./commands/db-init": {
      "types": "./dist/commands/db-init.d.mts",
      "import": "./dist/commands/db-init.mjs"
    },
    "./commands/db-update": {
      "types": "./dist/commands/db-update.d.mts",
      "import": "./dist/commands/db-update.mjs"
    },
    "./commands/db-schema": {
      "types": "./dist/commands/db-schema.d.mts",
      "import": "./dist/commands/db-schema.mjs"
    },
    "./commands/db-sign": {
      "types": "./dist/commands/db-sign.d.mts",
      "import": "./dist/commands/db-sign.mjs"
    },
    "./commands/db-verify": {
      "types": "./dist/commands/db-verify.d.mts",
      "import": "./dist/commands/db-verify.mjs"
