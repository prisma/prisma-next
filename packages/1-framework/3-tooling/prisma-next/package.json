{
  "name": "prisma-next",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Prisma Next CLI: emit, verify, sign, and migrate databases from a type-safe contract.",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "lint": "node ./scripts/lint-sync.mjs",
    "clean": "rm -rf dist"
  },
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@dagrejs/dagre": "^3.0.0",
    "@prisma-next/config": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/errors": "workspace:*",
    "@prisma-next/framework-components": "workspace:*",
    "@prisma-next/migration-tools": "workspace:*",
    "@prisma-next/psl-printer": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0",
    "c12": "^3.3.2",
    "closest-match": "^1.3.3",
    "colorette": "^2.0.20",
    "commander": "^12.0.0",
    "esbuild": "^0.25.11",
    "jsonc-parser": "^3.3.1",
    "package-manager-detector": "^1.6.0",
    "pathe": "^2.0.3",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.1.2",
    "wrap-ansi": "^10.0.0"
  },
  "devDependencies": {
    "@prisma-next/cli": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/3-tooling/prisma-next"
