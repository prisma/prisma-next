{
  "name": "@prisma-next/emitter",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "test"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "node ../../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/core-control-plane": "workspace:*",
    "arktype": "^2.0.0"
  },
  "devDependencies": {
    "@prisma-next/operations": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/src/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    },
    "./test/utils": {
      "types": "./dist/test/utils.d.ts",
      "import": "./dist/test/utils.js"
    }
  }
}
