{
  "name": "@prisma-next/migration-tools",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "On-disk migration persistence, attestation, and chain reconstruction for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "bench:large": "PN_BENCH_LARGE=1 vitest bench --run",
    "bench:save": "vitest bench --run --outputJson=bench/results/latest.json",
    "bench:compare": "vitest bench --run --compare=bench/results/latest.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/framework-components": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "catalog:",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    "./types": {
      "types": "./dist/exports/types.d.mts",
      "import": "./dist/exports/types.mjs"
    },
    "./io": {
      "types": "./dist/exports/io.d.mts",
      "import": "./dist/exports/io.mjs"
    },
    "./attestation": {
      "types": "./dist/exports/attestation.d.mts",
      "import": "./dist/exports/attestation.mjs"
    },
    "./dag": {
      "types": "./dist/exports/dag.d.mts",
      "import": "./dist/exports/dag.mjs"
    },
    "./refs": {
      "types": "./dist/exports/refs.d.mts",
      "import": "./dist/exports/refs.mjs"
    },
    "./constants": {
      "types": "./dist/exports/constants.d.mts",
      "import": "./dist/exports/constants.mjs"
    },
    "./migration-ts": {
      "types": "./dist/exports/migration-ts.d.mts",
      "import": "./dist/exports/migration-ts.mjs"
    },
    "./migration": {
      "types": "./dist/exports/migration.d.mts",
      "import": "./dist/exports/migration.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/3-tooling/migration"
  }
}
