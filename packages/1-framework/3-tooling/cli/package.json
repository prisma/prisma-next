{
  "name": "@prisma-next/cli",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json --declaration --declarationMap --emitDeclarationOnly",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../../biome.json --error-on-warnings",
    "lint:fix": "biome check --write . --config-path ../../../../biome.json",
    "lint:fix:unsafe": "biome check --write --unsafe . --config-path ../../../../biome.json",
    "clean": "node ../../../../scripts/clean.mjs"
  },
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/core-control-plane": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0",
    "c12": "^3.3.2",
    "colorette": "^2.0.20",
    "commander": "^12.0.0",
    "esbuild": "^0.19.0",
    "ora": "^8.1.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.2",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-emitter": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config-types": {
      "types": "./dist/config-types.d.ts",
      "import": "./dist/config-types.js"
    },
    "./commands/db-init": {
      "types": "./dist/commands/db-init.d.ts",
      "import": "./dist/commands/db-init.js"
    },
    "./commands/db-introspect": {
      "types": "./dist/commands/db-introspect.d.ts",
      "import": "./dist/commands/db-introspect.js"
    },
    "./commands/db-schema-verify": {
      "types": "./dist/commands/db-schema-verify.d.ts",
      "import": "./dist/commands/db-schema-verify.js"
    },
    "./commands/db-sign": {
      "types": "./dist/commands/db-sign.d.ts",
      "import": "./dist/commands/db-sign.js"
    },
    "./commands/db-verify": {
      "types": "./dist/commands/db-verify.d.ts",
      "import": "./dist/commands/db-verify.js"
    },
    "./commands/contract-emit": {
      "types": "./dist/commands/contract-emit.d.ts",
      "import": "./dist/commands/contract-emit.js"
    },
    "./config-loader": {
      "types": "./dist/config-loader.d.ts",
      "import": "./dist/config-loader.js"
    }
  }
}
