{
  "name": "@prisma-next/cli",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/core-control-plane": "workspace:*",
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0",
    "c12": "^3.3.2",
    "colorette": "^2.0.20",
    "commander": "^12.0.0",
    "esbuild": "^0.19.0",
    "ora": "^8.1.1",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.2",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-emitter": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    "./commands/contract-emit": "./src/commands/contract-emit.ts",
    "./commands/db-init": "./src/commands/db-init.ts",
    "./commands/db-introspect": "./src/commands/db-introspect.ts",
    "./commands/db-schema-verify": "./src/commands/db-schema-verify.ts",
    "./commands/db-sign": "./src/commands/db-sign.ts",
    "./commands/db-verify": "./src/commands/db-verify.ts",
    "./config-loader": "./src/config-loader.ts",
    ".": "./src/exports/index.ts",
    "./config-types": "./src/exports/config-types.ts",
    "./control-api": "./src/exports/control-api.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./commands/contract-emit": "./dist/commands/contract-emit.mjs",
      "./commands/db-init": "./dist/commands/db-init.mjs",
      "./commands/db-introspect": "./dist/commands/db-introspect.mjs",
      "./commands/db-schema-verify": "./dist/commands/db-schema-verify.mjs",
      "./commands/db-sign": "./dist/commands/db-sign.mjs",
      "./commands/db-verify": "./dist/commands/db-verify.mjs",
      "./config-loader": "./dist/config-loader.mjs",
      ".": "./dist/exports/index.mjs",
      "./config-types": "./dist/exports/config-types.mjs",
      "./control-api": "./dist/exports/control-api.mjs",
      "./package.json": "./package.json"
    }
  }
}
