{
  "name": "@prisma-next/runtime-executor",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Target-agnostic execution engine for Prisma Next",
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../biome.json --error-on-warnings",
    "lint:fix": "biome check --write . --config-path ../../../biome.json",
    "lint:fix:unsafe": "biome check --write --unsafe . --config-path ../../../biome.json",
    "clean": "node ../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "arktype": "^2.1.25"
  },
  "devDependencies": {
    "@prisma/dev": "catalog:",
    "@prisma-next/test-utils": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "catalog:"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
