{
  "name": "@prisma-next/ids",
  "version": "0.8.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "ID generator helpers for Prisma Next contracts",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.8.0",
    "@prisma-next/framework-components": "workspace:0.8.0",
    "@prisma-next/utils": "workspace:0.8.0",
    "uniku": "^0.0.12"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:0.8.0",
    "@prisma-next/tsdown": "workspace:0.8.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/1-framework/2-authoring/ids"
  }
}
