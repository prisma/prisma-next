{
  "name": "@prisma-next/ids",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "ID generator helpers for Prisma Next contracts",
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/contract-authoring": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "uniku": "^0.0.12"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    }
  }
}
