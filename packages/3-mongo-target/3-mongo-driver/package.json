{
  "name": "@prisma-next/driver-mongo",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "MongoDB driver for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/errors": "workspace:*",
    "@prisma-next/framework-components": "workspace:*",
    "@prisma-next/mongo-lowering": "workspace:*",
    "@prisma-next/mongo-wire": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "mongodb": "catalog:"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "mongodb-memory-server": "^10.4.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./control": "./dist/control.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/3-mongo-target/3-mongo-driver"
  }
}
