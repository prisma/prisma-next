    "typecheck": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/relational-ir": "workspace:*",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsup": "^8.2.4",
    "vitest": "^2.1.1"
  }
}
