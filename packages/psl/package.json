{
  "name": "@prisma/psl",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "psl": "./bin/psl.js"
  },
  "scripts": {
    "build": "../../node_modules/.bin/tsc",
