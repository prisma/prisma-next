{
  "id": "pgvector",
  "version": "1.0.0",
  "targets": {
    "postgres": {
      "minVersion": "12"
    }
  },
  "capabilities": {
    "postgres": {
      "pgvector/cosine": true
    }
  },
  "types": {
    "codecTypes": {
      "import": {
        "package": "@prisma-next/extension-pgvector/codec-types",
        "named": "CodecTypes",
        "alias": "PgVectorTypes"
      }
    },
    "operationTypes": {
      "import": {
        "package": "@prisma-next/extension-pgvector/operation-types",
        "named": "OperationTypes",
        "alias": "PgVectorOperationTypes"
      }
    }
  },
  "operations": [
    {
      "for": "pg/vector@1",
      "method": "cosineDistance",
      "args": [
        {
          "kind": "typeId",
          "type": "pg/vector@1"
        }
      ],
      "returns": {
        "kind": "builtin",
        "type": "number"
      },
      "lowering": {
        "targetFamily": "sql",
        "strategy": "function",
        "template": "1 - ({{self}} <=> {{arg0}})"
      }
    }
  ]
}
