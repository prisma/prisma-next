{
  "name": "@prisma/schema-emitter",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit && tsc --noEmit --skipLibCheck $(find src test -name '*.ts' 2>/dev/null || true)",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/psl": "workspace:*",
    "@prisma/relational-ir": "workspace:*",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsup": "^8.2.4",
    "vitest": "^2.1.1"
  }
}
