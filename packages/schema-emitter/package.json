{
  "name": "@prisma/schema-emitter",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "npx tsup src/index.ts --watch --format esm --dts",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/psl": "workspace:*",
    "@prisma/relational-ir": "workspace:*",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "tsup": "^8.2.4",
    "vitest": "^2.1.1"
  }
}
