{
  "name": "@prisma-next/cast-utils",
  "version": "0.11.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "Named, auditable alternatives to bare `as` casts in TypeScript — `blindCast` (last-resort, requires an articulated reason) and `castAs` (type-checked pass-through).",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:0.11.0",
    "@prisma-next/tsdown": "workspace:0.11.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/0-shared/cast-utils"
  }
}
