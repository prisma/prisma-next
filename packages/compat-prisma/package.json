{
  "name": "@prisma-next/compat-prisma",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../biome.json"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/runtime": "workspace:*",
    "@prisma-next/sql-query": "workspace:*",
    "@prisma-next/adapter-postgres": "workspace:*",
    "@prisma-next/driver-postgres": "workspace:*"
  },
  "devDependencies": {
    "@prisma/dev": "^0.1.1",
    "@types/pg": "^8.11.10",
    "pg": "^8.11.5",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    }
  }
}
