{
  "name": "@prisma-next/sql-relational-core",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "Schema and column builders, operation attachment, and AST types for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "@prisma-next/plan": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./ast": "./src/exports/ast.ts",
    "./errors": "./src/exports/errors.ts",
    "./guards": "./src/exports/guards.ts",
    "./operations-registry": "./src/exports/operations-registry.ts",
    "./param": "./src/exports/param.ts",
    "./plan": "./src/exports/plan.ts",
    "./query-lane-context": "./src/exports/query-lane-context.ts",
    "./schema": "./src/exports/schema.ts",
    "./types": "./src/exports/types.ts",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./ast": "./dist/exports/ast.mjs",
      "./errors": "./dist/exports/errors.mjs",
      "./guards": "./dist/exports/guards.mjs",
      "./operations-registry": "./dist/exports/operations-registry.mjs",
      "./param": "./dist/exports/param.mjs",
      "./plan": "./dist/exports/plan.mjs",
      "./query-lane-context": "./dist/exports/query-lane-context.mjs",
      "./schema": "./dist/exports/schema.mjs",
      "./types": "./dist/exports/types.mjs",
      "./package.json": "./package.json"
    }
  }
}
