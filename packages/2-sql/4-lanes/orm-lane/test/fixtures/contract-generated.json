          "email": {
            "nativeType": "text",
            "codecId": "pg/text@1",
            "nullable": false
          }
        },
        "primaryKey": {
          "columns": ["id"]
        },
        "uniques": [],
        "indexes": [],
        "foreignKeys": []
      }
    }
  },
  "execution": {
