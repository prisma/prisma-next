{
  "name": "@prisma-next/family-sql",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "description": "SQL family descriptor for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/core-control-plane": "workspace:*",
    "@prisma-next/core-execution-plane": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "@prisma-next/runtime-executor": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-emitter": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "@prisma-next/sql-relational-core": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/sql-schema-ir": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0"
  },
  "devDependencies": {
    "@prisma-next/driver-postgres": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./control": "./src/exports/control.ts",
    "./control-adapter": "./src/exports/control-adapter.ts",
    "./runtime": "./src/exports/runtime.ts",
    "./schema-verify": "./src/exports/schema-verify.ts",
    "./test-utils": "./src/exports/test-utils.ts",
    "./verify": "./src/exports/verify.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./control": "./dist/control.mjs",
      "./control-adapter": "./dist/control-adapter.mjs",
      "./runtime": "./dist/runtime.mjs",
      "./schema-verify": "./dist/schema-verify.mjs",
      "./test-utils": "./dist/test-utils.mjs",
      "./verify": "./dist/verify.mjs",
      "./package.json": "./package.json"
    }
  }
}
