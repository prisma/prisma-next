{
  "name": "@prisma-next/family-sql",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "SQL family descriptor for Prisma Next",
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../../biome.json --error-on-warnings",
    "clean": "node ../../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/core-control-plane": "workspace:*",
    "@prisma-next/core-execution-plane": "workspace:*",
    "@prisma-next/operations": "workspace:*",
    "@prisma-next/runtime-executor": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-emitter": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-operations": "workspace:*",
    "@prisma-next/sql-relational-core": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/sql-schema-ir": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.0.0"
  },
  "devDependencies": {
    "@prisma-next/driver-postgres": "workspace:*",
    "@prisma-next/test-utils": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./control": {
      "types": "./dist/exports/control.d.ts",
      "import": "./dist/exports/control.js"
    },
    "./control-adapter": {
      "types": "./dist/exports/control-adapter.d.ts",
      "import": "./dist/exports/control-adapter.js"
    },
    "./runtime": {
      "types": "./dist/exports/runtime.d.ts",
      "import": "./dist/exports/runtime.js"
    },
    "./verify": {
      "types": "./dist/exports/verify.d.ts",
      "import": "./dist/exports/verify.js"
    },
    "./test-utils": {
      "types": "./dist/exports/test-utils.d.ts",
      "import": "./dist/exports/test-utils.js"
    },
    "./schema-verify": {
      "types": "./dist/exports/schema-verify.d.ts",
      "import": "./dist/exports/schema-verify.js"
    }
  }
}
