{
  "name": "@prisma-next/sql-contract",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "SQL contract types, validators, and IR factories for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "arktype": "^2.1.25"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./factories": "./dist/factories.mjs",
    "./pack-types": "./dist/pack-types.mjs",
    "./types": "./dist/types.mjs",
    "./validate": "./dist/validate.mjs",
    "./validators": "./dist/validators.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/2-sql/1-core/contract"
  }
}
