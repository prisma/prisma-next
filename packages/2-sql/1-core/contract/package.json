{
  "name": "@prisma-next/sql-contract",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "description": "SQL contract types, validators, and IR factories for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "arktype": "^2.1.25"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./factories": "./src/exports/factories.ts",
    "./pack-types": "./src/exports/pack-types.ts",
    "./types": "./src/exports/types.ts",
    "./validators": "./src/exports/validators.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./factories": "./dist/factories.mjs",
      "./pack-types": "./dist/pack-types.mjs",
      "./types": "./dist/types.mjs",
      "./validators": "./dist/validators.mjs",
      "./package.json": "./package.json"
    }
  }
}
