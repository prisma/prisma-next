{
  "name": "@prisma-next/sql-runtime",
  "version": "0.8.0",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "description": "SQL runtime implementation for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:0.8.0",
    "@prisma-next/utils": "workspace:0.8.0",
    "@prisma-next/framework-components": "workspace:0.8.0",
    "@prisma-next/ids": "workspace:0.8.0",
    "@prisma-next/operations": "workspace:0.8.0",
    "@prisma-next/sql-contract": "workspace:0.8.0",
    "@prisma-next/sql-operations": "workspace:0.8.0",
    "@prisma-next/sql-relational-core": "workspace:0.8.0",
    "arktype": "^2.1.29"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:0.8.0",
    "@prisma-next/tsconfig": "workspace:0.8.0",
    "@types/pg": "catalog:",
    "pg": "catalog:",
    "@prisma-next/tsdown": "workspace:0.8.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./test/utils": "./dist/test/utils.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/2-sql/5-runtime"
  }
}
