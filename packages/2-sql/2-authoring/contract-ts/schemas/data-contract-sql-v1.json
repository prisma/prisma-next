{
  "$id": "https://prisma.dev/schemas/data-contract-sql-v1.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Prisma Next Data Contract SQL v1",
  "description": "Schema for Prisma Next contract.json files for the SQL family (postgres, mysql, sqlite, etc.)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this JSON schema for IDE validation"
    },
    "schemaVersion": {
      "type": "string",
      "enum": ["1"],
      "description": "Contract schema version"
    },
    "target": {
      "type": "string",
      "description": "Database target identifier (e.g., 'postgres', 'mysql', 'sqlite')"
    },
    "targetFamily": {
      "type": "string",
      "enum": ["sql"],
      "description": "Target family classification"
    },
    "coreHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the core schema structure (models, fields, relations, storage layout)"
    },
    "profileHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of the pinned capability profile (capability keys/variants and adapter pins)"
    },
    "capabilities": {
      "type": "object",
      "description": "Capability flags declared by the contract",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "boolean"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "Extension packs and their configuration",
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "description": "Non-semantic metadata (excluded from hashing)",
      "additionalProperties": true
    },
    "sources": {
      "type": "object",
      "description": "Read-only sources (views, etc.) available for querying",
      "additionalProperties": {
        "$ref": "#/$defs/Source"
      }
    },
    "models": {
      "type": "object",
      "description": "Model definitions mapping application-level models to storage tables",
      "additionalProperties": {
        "$ref": "#/$defs/Model"
      }
    },
    "storage": {
      "type": "object",
      "description": "Storage layout definition",
      "additionalProperties": false,
      "properties": {
        "tables": {
          "type": "object",
          "description": "Table definitions keyed by table name",
          "additionalProperties": {
            "$ref": "#/$defs/StorageTable"
          }
        },
        "types": {
          "type": "object",
          "description": "Named type instances for parameterized/custom types (e.g., vectors, enums)",
          "additionalProperties": {
            "$ref": "#/$defs/StorageTypeInstance"
          }
        }
      },
      "required": ["tables"]
    }
  },
  "required": ["schemaVersion", "target", "targetFamily", "coreHash", "models", "storage"],
  "$defs": {
    "StorageTable": {
      "type": "object",
      "description": "Table definition with columns, constraints, and indexes",
      "additionalProperties": false,
      "properties": {
        "columns": {
          "type": "object",
          "description": "Column definitions keyed by column name",
          "additionalProperties": {
            "$ref": "#/$defs/StorageColumn"
          }
        },
        "primaryKey": {
          "$ref": "#/$defs/PrimaryKey",
          "description": "Primary key constraint definition"
        },
        "uniques": {
          "type": "array",
          "description": "Unique constraint definitions",
          "items": {
            "$ref": "#/$defs/UniqueConstraint"
          }
        },
        "indexes": {
          "type": "array",
          "description": "Index definitions",
          "items": {
            "$ref": "#/$defs/Index"
          }
        },
        "foreignKeys": {
          "type": "array",
          "description": "Foreign key constraint definitions",
          "items": {
            "$ref": "#/$defs/ForeignKey"
          }
        }
      },
      "required": ["columns"]
    },
    "ColumnDefault": {
      "description": "Column default value. Can be a literal value, database function, sequence reference, or raw expression.",
      "oneOf": [
        {
          "type": "object",
          "description": "Static literal value",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["literal"]
            },
            "value": {
              "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }],
              "description": "The literal default value"
            }
          },
          "required": ["kind", "value"]
        },
        {
          "type": "object",
          "description": "Database function (autoincrement, now, uuid, cuid)",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["function"]
            },
            "name": {
              "type": "string",
              "enum": ["autoincrement", "now", "uuid", "cuid"],
              "description": "Function name"
            }
          },
          "required": ["kind", "name"]
        },
        {
          "type": "object",
          "description": "Named sequence reference",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["sequence"]
            },
            "name": {
              "type": "string",
              "description": "Sequence name"
            }
          },
          "required": ["kind", "name"]
        },
        {
          "type": "object",
          "description": "Raw database expression (escape hatch)",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["dbGenerated"]
            },
            "expression": {
              "type": "string",
              "description": "Raw SQL expression for the default value"
            }
          },
          "required": ["kind", "expression"]
        }
      ]
    },
    "StorageColumn": {
      "type": "object",
      "description": "Column definition with type, nullability, and optional parameterized type info",
      "additionalProperties": false,
      "properties": {
        "nativeType": {
          "type": "string",
          "description": "Database-native type (e.g., 'text', 'int4', 'timestamptz', 'vector(1536)')"
        },
        "codecId": {
          "type": "string",
          "description": "Codec identifier for encoding/decoding (e.g., 'pg/text@1', 'pg/vector@1')"
        },
        "nullable": {
          "type": "boolean",
          "default": false,
          "description": "Whether the column allows NULL values"
        },
        "typeParams": {
          "type": "object",
          "description": "Opaque, codec-owned JS/type parameters (e.g., { length: 1536 } for vectors)",
          "additionalProperties": true
        },
        "typeRef": {
          "type": "string",
          "description": "Reference to a named type instance in storage.types"
        },
        "default": {
          "$ref": "#/$defs/ColumnDefault",
          "description": "Default value for the column"
        }
      },
      "required": ["nativeType", "codecId", "nullable"]
    },
    "StorageTypeInstance": {
      "type": "object",
      "description": "Named, parameterized type instance for reuse across columns",
      "additionalProperties": false,
      "properties": {
        "codecId": {
          "type": "string",
          "description": "Codec identifier for encoding/decoding"
        },
        "nativeType": {
          "type": "string",
          "description": "Database-native type"
        },
        "typeParams": {
          "type": "object",
          "description": "Codec-owned type parameters",
          "additionalProperties": true
        }
      },
      "required": ["codecId", "nativeType", "typeParams"]
    },
    "PrimaryKey": {
      "type": "object",
      "description": "Primary key constraint",
      "additionalProperties": false,
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column names comprising the primary key",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "name": {
          "type": "string",
          "description": "Constraint name (e.g., 'user_pkey')"
        }
      },
      "required": ["columns"]
    },
    "UniqueConstraint": {
      "type": "object",
      "description": "Unique constraint",
      "additionalProperties": false,
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column names comprising the unique constraint",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "name": {
          "type": "string",
          "description": "Constraint name (e.g., 'user_email_key')"
        }
      },
      "required": ["columns"]
    },
    "Index": {
      "type": "object",
      "description": "Index definition (structure may vary by target)",
      "additionalProperties": false,
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column names indexed",
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string",
          "description": "Index name"
        }
      }
    },
    "ForeignKey": {
      "type": "object",
      "description": "Foreign key constraint definition",
      "additionalProperties": false,
      "properties": {
        "columns": {
          "type": "array",
          "description": "Column names in the referencing table",
          "items": {
            "type": "string"
          }
        },
        "references": {
          "type": "object",
          "description": "Referenced table and columns",
          "additionalProperties": false,
          "properties": {
            "table": {
              "type": "string",
              "description": "Referenced table name"
            },
            "columns": {
              "type": "array",
              "description": "Referenced column names",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["table", "columns"]
        },
        "name": {
          "type": "string",
          "description": "Foreign key constraint name"
        }
      },
      "required": ["columns", "references"]
    },
    "FieldType": {
      "type": "object",
      "description": "Neutral field type definition for sources and document fields",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Field type identifier (e.g., 'int4', 'text', 'bool', 'object', 'array', 'date', 'bytes', 'id')"
        },
        "nullable": {
          "type": "boolean",
          "default": false,
          "description": "Whether the field allows null values"
        },
        "items": {
          "$ref": "#/$defs/FieldType",
          "description": "Item type for array fields"
        },
        "properties": {
          "type": "object",
          "description": "Property definitions for object fields",
          "additionalProperties": {
            "$ref": "#/$defs/FieldType"
          }
        }
      },
      "required": ["type", "nullable"]
    },
    "Source": {
      "type": "object",
      "description": "Read-only source definition for views and other queryable sources",
      "additionalProperties": false,
      "properties": {
        "readOnly": {
          "type": "boolean",
          "description": "Whether mutations (INSERT/UPDATE/DELETE) are disallowed"
        },
        "projection": {
          "type": "object",
          "description": "Field projection mapping column/field name to FieldType",
          "additionalProperties": {
            "$ref": "#/$defs/FieldType"
          }
        },
        "origin": {
          "type": "object",
          "description": "Provenance link to pack-owned block (e.g., view, enum)",
          "additionalProperties": true
        },
        "capabilities": {
          "type": "object",
          "description": "Feature flags relevant to this source",
          "additionalProperties": {
            "type": "boolean"
          }
        }
      },
      "required": ["readOnly", "projection"]
    },
    "Model": {
      "type": "object",
      "description": "Model definition mapping to storage table",
      "additionalProperties": false,
      "properties": {
        "storage": {
          "type": "object",
          "description": "Storage mapping for the model",
          "additionalProperties": false,
          "properties": {
            "table": {
              "type": "string",
              "description": "Table name in storage.tables"
            }
          },
          "required": ["table"]
        },
        "fields": {
          "type": "object",
          "description": "Field definitions mapping model fields to storage columns",
          "additionalProperties": {
            "$ref": "#/$defs/ModelField"
          }
        },
        "relations": {
          "type": "object",
          "description": "Relation definitions for the model",
          "additionalProperties": {
            "$ref": "#/$defs/ModelRelation"
          }
        }
      },
      "required": ["storage", "fields"]
    },
    "ModelField": {
      "type": "object",
      "description": "Model field definition mapping to storage column",
      "additionalProperties": false,
      "properties": {
        "column": {
          "type": "string",
          "description": "Column name in the model's backing table"
        }
      },
      "required": ["column"]
    },
    "ModelRelation": {
      "type": "object",
      "description": "Model relation definition",
      "additionalProperties": false,
      "properties": {
        "to": {
          "type": "string",
          "description": "Target model name"
        },
        "cardinality": {
          "type": "string",
          "enum": ["1:1", "1:N", "N:1", "N:M"],
          "description": "Relation cardinality"
        },
        "on": {
          "type": "object",
          "description": "Relation field mappings",
          "additionalProperties": false,
          "properties": {
            "parentCols": {
              "type": "array",
              "description": "Parent table columns",
              "items": {
                "type": "string"
              }
            },
            "childCols": {
              "type": "array",
              "description": "Child table columns",
              "items": {
                "type": "string"
              }
            }
          },
          "required": ["parentCols", "childCols"]
        }
      },
      "required": ["to", "cardinality", "on"]
    }
  }
}
