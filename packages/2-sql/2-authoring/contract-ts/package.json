{
  "name": "@prisma-next/sql-contract-ts",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "SQL-specific TypeScript contract authoring surface for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist dist-tsc dist-tsc-prod coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/config": "workspace:*",
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/contract-authoring": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/utils": "workspace:*",
    "arktype": "^2.1.25",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@types/pg": "catalog:",
    "pg": "catalog:",
    "@prisma-next/tsdown": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "exports": {
    "./config-types": "./dist/config-types.mjs",
    "./contract-builder": "./dist/contract-builder.mjs",
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/prisma/prisma-next.git",
    "directory": "packages/2-sql/2-authoring/contract-ts"
  }
}
