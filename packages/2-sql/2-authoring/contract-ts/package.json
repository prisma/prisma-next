{
  "name": "@prisma-next/sql-contract-ts",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "description": "SQL-specific TypeScript contract authoring surface for Prisma Next",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/contract-authoring": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "arktype": "^2.1.25",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "@types/pg": "catalog:",
    "pg": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "exports": {
    "./contract": "./src/exports/contract.ts",
    "./contract-builder": "./src/exports/contract-builder.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./contract": "./dist/contract.mjs",
      "./contract-builder": "./dist/contract-builder.mjs",
      "./package.json": "./package.json"
    }
  }
}
