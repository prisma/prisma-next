{
  "name": "@prisma-next/sql-contract-ts",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "description": "SQL-specific TypeScript contract authoring surface for Prisma Next",
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../../biome.json --error-on-warnings",
    "lint:fix": "biome check --write . --config-path ../../../../biome.json",
    "lint:fix:unsafe": "biome check --write --unsafe . --config-path ../../../../biome.json",
    "clean": "node ../../../../scripts/clean.mjs"
  },
  "dependencies": {
    "@prisma-next/contract": "workspace:*",
    "@prisma-next/contract-authoring": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "arktype": "^2.1.25",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@prisma-next/test-utils": "workspace:*",
    "@types/pg": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "pg": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "exports": {
    "./contract-builder": {
      "types": "./dist/exports/contract-builder.d.ts",
      "import": "./dist/exports/contract-builder.js"
    },
    "./contract": {
      "types": "./dist/exports/contract.d.ts",
      "import": "./dist/exports/contract.js"
    },
    "./schema-sql": "./schemas/data-contract-sql-v1.json"
  }
}
