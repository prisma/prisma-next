{
  "name": "@prisma-next/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../biome.json"
  },
  "bin": {
    "prisma-next": "./dist/cli.js"
  },
  "dependencies": {
    "@prisma-next/emitter": "workspace:*",
    "@prisma-next/node-utils": "workspace:*",
    "@prisma-next/sql-target": "workspace:*",
    "commander": "^12.0.0",
    "esbuild": "^0.19.0"
  },
  "devDependencies": {
    "@prisma-next/sql-query": "workspace:*",
    "@prisma-next/sql-target": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
