{
  "name": "@prisma/cli",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prisma-next": "./bin/prisma-next.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "npx tsup src/index.ts --watch --format esm --dts",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/psl": "workspace:*",
    "@prisma/relational-ir": "workspace:*",
    "@prisma/schema-emitter": "workspace:*",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsup": "^8.5.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
