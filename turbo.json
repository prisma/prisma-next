{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json", "tsdown.config.ts"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "dist/**"],
      "env": ["TEST_TIMEOUT_MULTIPLIER"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "dist/**"],
      "outputs": ["coverage/**"],
      "env": ["TEST_TIMEOUT_MULTIPLIER"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "tsconfig.json"]
    },
    "lint": {
      "inputs": ["src/**", "test/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
