// db.users.include('posts', p => p.include('comments')).all()
digraph {
  label="db.users.include('posts', p => p.include('comments')).all()"
  labelloc=t
  fontsize=16
  fontname="Helvetica-Bold"
  rankdir=BT
  node [fontname="Helvetica" fontsize=11 style=filled]
  edge [fontname="Helvetica" fontsize=9]

  // Nodes
  start [label="Start" shape=circle fillcolor=white]
  cs_users_0 [label="CollectionState\n(users, 0)" shape=box fillcolor=gray90 color=gray60 fontcolor=gray40]
  cs_posts_0 [label="CollectionState\n(posts, 0)" shape=box fillcolor=gray90 color=gray60 fontcolor=gray40]
  cs_comments_0 [label="CollectionState\n(comments, 0)" shape=box fillcolor=gray90 color=gray60 fontcolor=gray40]
  read_users [label="Read\n(users, [*])" shape=box fillcolor="#dae8fc" color="#6c8ebf"]
  read_posts [label="Read\n(posts, [*])" shape=box fillcolor="#dae8fc" color="#6c8ebf"]
  read_comments [label="Read\n(comments, [*])" shape=box fillcolor="#dae8fc" color="#6c8ebf"]
  nest_comments [label="Nest\nleftKeys=[id]\nrightKeys=[postId]\nfield=comments" shape=box fillcolor="#d5e8d4" color="#82b366"]
  nest_posts [label="Nest\nleftKeys=[id]\nrightKeys=[userId]\nfield=posts" shape=box fillcolor="#d5e8d4" color="#82b366"]
  ret [label="Return" shape=doublecircle fillcolor=black fontcolor=white]

  // Edges
  cs_users_0 -> start [color=gray60]
  cs_posts_0 -> start [color=gray60]
  cs_comments_0 -> start [color=gray60]
  read_users -> cs_users_0 [color=gray60]
  read_posts -> read_users [label="FilterData\n(users.id -> posts.userId)" color="#2196F3" fontcolor="#2196F3"]
  read_posts -> cs_posts_0 [color=gray60]
  read_comments -> read_posts [label="FilterData\n(posts.id -> comments.postId)" color="#2196F3" fontcolor="#2196F3"]
  read_comments -> cs_comments_0 [color=gray60]
  nest_comments -> read_posts [label="left" color=gray60]
  nest_comments -> read_comments [label="right" color=gray60]
  nest_posts -> read_users [label="left" color=gray60]
  nest_posts -> nest_comments [label="right" color=gray60]
  ret -> nest_posts [color=gray60]
  ret -> cs_users_0 [color=gray60 style=dashed]
  ret -> cs_posts_0 [color=gray60 style=dashed]
  ret -> cs_comments_0 [color=gray60 style=dashed]
}
