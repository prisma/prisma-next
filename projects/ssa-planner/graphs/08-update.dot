// db.users.where({ id: 1 }).update({ name: 'Bob' })
digraph {
  label="db.users.where({ id: 1 }).update({ name: 'Bob' })"
  labelloc=t
  fontsize=16
  fontname="Helvetica-Bold"
  rankdir=BT
  node [fontname="Helvetica" fontsize=11 style=filled]
  edge [fontname="Helvetica" fontsize=9]

  // Nodes
  start [label="Start" shape=circle fillcolor=white]
  cs_users_0 [label="CollectionState\n(users, 0)" shape=box fillcolor=gray90 color=gray60 fontcolor=gray40]
  read_a [label="Read (A)\n(users, [id]\nwhere=[id = 1])" shape=box fillcolor="#dae8fc" color="#6c8ebf"]
  update_users [label="Update\n(users)\ndata={name:'Bob'}\nwhere=[id = 1]" shape=box fillcolor="#ffccbc" color="#e64a19"]
  cs_users_1 [label="CollectionState\n(users, 1)" shape=box fillcolor=gray90 color=gray60 fontcolor=gray40]
  read_b [label="Read (B)\n(users, [*])" shape=box fillcolor="#dae8fc" color="#6c8ebf"]
  ret [label="Return" shape=doublecircle fillcolor=black fontcolor=white]

  // Edges
  cs_users_0 -> start [color=gray60]
  read_a -> cs_users_0 [color=gray60]
  update_users -> read_a [label="FilterData\n(users.id -> users.id)" color="#2196F3" fontcolor="#2196F3"]
  update_users -> cs_users_0 [color=gray60]
  cs_users_1 -> update_users [color=gray60]
  read_b -> read_a [label="FilterData\n(users.id -> users.id)" color="#2196F3" fontcolor="#2196F3"]
  read_b -> cs_users_1 [color=gray60]
  ret -> read_b [color=gray60]
  ret -> cs_users_1 [color=gray60 style=dashed]
}
