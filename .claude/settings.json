{
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/scripts/worktree-create.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(cat:*)",
      "Skill(bumping-biome)",
      "Bash(pnpm list:*)",
      "mcp__ide__getDiagnostics",
      "Skill(tsdown-package)",
      "Bash(ls:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm test:packages:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm lint:deps:*)",
      "Bash(gh pr view:*)"
    ],
    "deny": [],
    "ask": []
  }
}
