{
  "packages": [
    {
      "glob": "packages/1-framework/1-core/shared/**",
      "domain": "framework",
      "layer": "core",
      "plane": "shared"
    },
    {
      "glob": "packages/1-framework/1-core/migration/**",
      "domain": "framework",
      "layer": "core",
      "plane": "migration"
    },
    {
      "glob": "packages/1-framework/1-core/runtime/**",
      "domain": "framework",
      "layer": "core",
      "plane": "runtime"
    },
    {
      "glob": "packages/1-framework/2-authoring/**",
      "domain": "framework",
      "layer": "authoring",
      "plane": "migration"
    },
    {
      "glob": "packages/1-framework/2-authoring/ids/**",
      "domain": "framework",
      "layer": "authoring",
      "plane": "migration"
    },
    {
      "glob": "packages/1-framework/3-tooling/**",
      "domain": "framework",
      "layer": "tooling",
      "plane": "migration"
    },
    {
      "glob": "packages/1-framework/3-tooling/eslint-plugin/**",
      "domain": "framework",
      "layer": "tooling",
      "plane": "migration"
    },
    {
      "glob": "packages/1-framework/4-runtime-executor/**",
      "domain": "framework",
      "layer": "runtime-executor",
      "plane": "runtime"
    },
    {
      "glob": "packages/2-sql/1-core/**",
      "domain": "sql",
      "layer": "core",
      "plane": "shared"
    },
    {
      "glob": "packages/2-sql/1-core/errors/**",
      "domain": "sql",
      "layer": "core",
      "plane": "shared"
    },
    {
      "glob": "packages/2-sql/2-authoring/**",
      "domain": "sql",
      "layer": "authoring",
      "plane": "migration"
    },
    {
      "glob": "packages/2-sql/3-tooling/emitter/**",
      "domain": "sql",
      "layer": "tooling",
      "plane": "migration"
    },
    {
      "glob": "packages/2-sql/3-tooling/family/src/core/**",
      "domain": "sql",
      "layer": "tooling",
      "plane": "shared"
    },
    {
      "glob": "packages/2-sql/3-tooling/family/src/exports/control.ts",
      "domain": "sql",
      "layer": "tooling",
      "plane": "migration"
    },
    {
      "glob": "packages/2-sql/3-tooling/family/src/exports/runtime.ts",
      "domain": "sql",
      "layer": "tooling",
      "plane": "runtime"
    },
    {
      "glob": "packages/2-sql/4-lanes/**",
      "domain": "sql",
      "layer": "lanes",
      "plane": "runtime"
    },
    {
      "glob": "packages/2-sql/5-runtime/**",
      "domain": "sql",
      "layer": "runtime",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/integration-kysely/**",
      "domain": "extensions",
      "layer": "integrations",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/sql-orm-client/**",
      "domain": "extensions",
      "layer": "integrations",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-targets/3-targets/postgres/src/exports/control.ts",
      "domain": "extensions",
      "layer": "targets",
      "plane": "migration"
    },
    {
      "glob": "packages/3-targets/3-targets/postgres/src/exports/runtime.ts",
      "domain": "extensions",
      "layer": "targets",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-targets/6-adapters/postgres/src/core/**",
      "domain": "targets",
      "layer": "adapters",
      "plane": "shared"
    },
    {
      "glob": "packages/3-targets/6-adapters/postgres/src/exports/control.ts",
      "domain": "targets",
      "layer": "adapters",
      "plane": "migration"
    },
    {
      "glob": "packages/3-targets/6-adapters/postgres/src/exports/runtime.ts",
      "domain": "targets",
      "layer": "adapters",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-targets/7-drivers/postgres/src/exports/control.ts",
      "domain": "targets",
      "layer": "drivers",
      "plane": "migration"
    },
    {
      "glob": "packages/3-targets/7-drivers/postgres/src/exports/runtime.ts",
      "domain": "targets",
      "layer": "drivers",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/postgres/src/runtime/**",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/postgres/src/exports/runtime.ts",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/core/**",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "shared"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/types/**",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "shared"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/exports/control.ts",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "migration"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/exports/runtime.ts",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "runtime"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/exports/codec-types.ts",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "shared"
    },
    {
      "glob": "packages/3-extensions/pgvector/src/exports/operation-types.ts",
      "domain": "extensions",
      "layer": "adapters",
      "plane": "shared"
    }
  ],
  "rules": {
    "sameLayer": "allow",
    "downward": "allow",
    "upward": "deny",
    "crossDomain": "directional",
    "migrationToRuntime": "deny",
    "runtimeToMigration": "allowArtifactsOnly"
  },
  "crossDomainRules": {
    "framework": {
      "mayImportFrom": [],
      "reason": "Framework domain is the innermost/core domain and may not import from any other domain"
    },
    "sql": {
      "mayImportFrom": ["framework"],
      "reason": "SQL domain may import only from framework domain"
    },
    "document": {
      "mayImportFrom": ["framework"],
      "reason": "Document domain may import only from framework domain"
    },
    "targets": {
      "mayImportFrom": ["framework", "sql"],
      "reason": "Targets domain may import from framework and sql domains"
    },
    "extensions": {
      "mayImportFrom": ["framework", "sql", "document", "targets", "extensions"],
      "reason": "Extensions domain may import from any domain"
    }
  },
  "planeRules": {
    "shared": {
      "allow": ["shared"],
      "forbid": ["migration", "runtime"],
      "exceptions": []
    },
    "migration": {
      "allow": ["shared", "migration"],
      "forbid": ["runtime"],
      "exceptions": []
    },
    "runtime": {
      "allow": ["shared", "runtime"],
      "forbid": ["migration"],
      "exceptions": []
    }
  },
  "crossDomainExceptions": [],
  "layerOrder": {
    "framework": ["core", "authoring", "tooling", "runtime-executor"],
    "sql": ["core", "authoring", "tooling", "lanes", "runtime", "adapters", "drivers"]
  }
}
