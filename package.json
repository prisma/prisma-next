{
  "name": "prisma-next",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "pnpm biome format --write .",
    "test": "turbo run test --continue",
    "test:packages": "turbo run test --filter='!./examples/**' --continue",
    "test:examples": "turbo run test --filter='./examples/**' --continue",
    "test:coverage": "turbo run test:coverage",
    "coverage:report": "node scripts/coverage-report.mjs",
    "coverage:packages": "turbo run test:coverage --filter='!./examples/**' --filter='!./packages/integration-tests' --filter='!./packages/e2e-tests'",
    "lint": "turbo run lint",
    "lint:fix": "pnpm biome check --write .",
    "lint:packages": "turbo run lint --filter='!./examples/**'",
    "lint:examples": "turbo run lint --filter='./examples/**'",
    "lint:deps": "node scripts/check-imports.mjs",
    "typecheck": "turbo run typecheck",
    "typecheck:all": "turbo run typecheck --include-examples",
    "typecheck:packages": "turbo run typecheck --filter='!./examples/**'",
    "typecheck:examples": "turbo run typecheck --filter='./examples/**'",
    "clean": "turbo run clean",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@changesets/cli": "^2.27.8",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,jsonc}": [
      "biome format --write",
      "biome check --write"
    ]
  }
}
