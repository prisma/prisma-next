{
  "name": "prisma-next",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:packages": "turbo run test:coverage --filter='!./examples/**'",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:all": "turbo run typecheck --include-examples",
    "typecheck:packages": "turbo run typecheck --filter='!./examples/**'",
    "typecheck:examples": "turbo run typecheck --filter='./examples/**'",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.8",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitest/coverage-v8": "^2.1.1",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
