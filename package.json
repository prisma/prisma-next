{
  "name": "prisma-next",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "format": "pnpm biome format --write .",
    "test": "turbo run test",
    "test:packages": "turbo run test --filter='!./examples/**'",
    "test:examples": "turbo run test --filter='./examples/**'",
    "test:coverage": "turbo run test:coverage",
    "test:coverage:packages": "turbo run test:coverage --filter='!./examples/**' --filter='!./packages/integration-tests' --filter='!./packages/e2e-tests'",
    "lint": "turbo run lint",
    "lint:all": "turbo run lint",
    "lint:packages": "turbo run lint --filter='!./examples/**'",
    "lint:examples": "turbo run lint --filter='./examples/**'",
    "typecheck": "turbo run typecheck",
    "typecheck:all": "turbo run typecheck --include-examples",
    "typecheck:packages": "turbo run typecheck --filter='!./examples/**'",
    "typecheck:examples": "turbo run typecheck --filter='./examples/**'",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@changesets/cli": "^2.27.8",
    "@types/node": "^24.7.2",
    "@vitest/coverage-v8": "^2.1.1",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
