{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@prisma/relational-ir": ["packages/relational-ir/src/index.ts"],
      "@prisma/psl": ["packages/psl/src/index.ts"],
      "@prisma/schema-emitter": ["packages/schema-emitter/src/index.ts"],
      "@prisma/sql": ["packages/sql/src/index.ts"],
      "@prisma/runtime": ["packages/runtime/src/index.ts"]
    }
  }
}

