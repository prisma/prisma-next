{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/adapter-postgres/*": ["packages/adapter-postgres/src/exports/*.ts"],
      "@prisma/driver-postgres": ["packages/driver-postgres/src/exports/index.ts"],
      "@prisma/driver-postgres/*": ["packages/driver-postgres/src/exports/*.ts"],
      "@prisma/runtime": ["packages/runtime/src/exports/index.ts"],
      "@prisma/runtime/*": ["packages/runtime/src/exports/*.ts"],
      "@prisma/sql-target": ["packages/sql-target/src/exports/index.ts"],
      "@prisma/sql-target/*": ["packages/sql-target/src/exports/*.ts"],
      "@prisma/sql/*": ["packages/sql/src/exports/*.ts"]
    }
  },
  "references": [
    { "path": "./packages/relational-ir" },
    { "path": "./packages/psl" },
    { "path": "./packages/sql-target" },
    { "path": "./packages/driver-postgres" },
    { "path": "./packages/sql" },
    { "path": "./packages/schema-emitter" },
    { "path": "./packages/runtime" },
    { "path": "./packages/cli" }
  ]
}
