{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@prisma-next/adapter-postgres/*": [
        "packages/sql/runtime/adapters/postgres/src/exports/*.ts"
      ],
      "@prisma-next/driver-postgres": [
        "packages/sql/runtime/drivers/postgres/src/exports/index.ts"
      ],
      "@prisma-next/driver-postgres/*": ["packages/sql/runtime/drivers/postgres/src/exports/*.ts"],
      "@prisma-next/contract": ["packages/framework/core-contract/src/exports/types.ts"],
      "@prisma-next/contract/*": ["packages/framework/core-contract/src/exports/*.ts"],
      "@prisma-next/cli": ["packages/framework/tooling/cli/src/exports/index.ts"],
      "@prisma-next/emitter": ["packages/framework/tooling/emitter/src/exports/index.ts"],
      "@prisma-next/emitter/*": ["packages/framework/tooling/emitter/src/exports/*.ts"],
      "@prisma-next/compat-prisma": ["packages/extensions/compat-prisma/src/exports/index.ts"],
      "@prisma-next/compat-prisma/*": ["packages/extensions/compat-prisma/src/exports/*.ts"],
      "@prisma-next/plan": ["packages/framework/core-plan/src/index.ts"],
      "@prisma-next/operations": ["packages/framework/core-operations/src/index.ts"],
      "@prisma-next/contract-authoring": [
        "packages/framework/authoring/contract-authoring/src/index.ts"
      ],
      "@prisma-next/contract-ts": ["packages/framework/authoring/contract-ts/src/index.ts"],
      "@prisma-next/contract-psl": ["packages/framework/authoring/contract-psl/src/index.ts"],
      "@prisma-next/sql-contract": ["packages/sql/contract/src/index.ts"],
      "@prisma-next/sql-contract/*": ["packages/sql/contract/src/exports/*.ts"],
      "@prisma-next/sql-operations": ["packages/sql/operations/src/index.ts"],
      "@prisma-next/sql-contract-emitter": ["packages/targets/sql/emitter/src/index.ts"],
      "@prisma-next/sql-relational-core": ["packages/sql/lanes/relational-core/src/index.ts"],
      "@prisma-next/sql-relational-core/*": ["packages/sql/lanes/relational-core/src/exports/*.ts"],
      "@prisma-next/sql-lane": ["packages/sql/lanes/sql-lane/src/index.ts"],
      "@prisma-next/sql-lane/*": ["packages/sql/lanes/sql-lane/src/exports/*.ts"],
      "@prisma-next/sql-orm-lane": ["packages/sql/lanes/orm-lane/src/index.ts"],
      "@prisma-next/sql-contract-ts/*": ["packages/sql/authoring/sql-contract-ts/src/exports/*.ts"],
      "@prisma-next/runtime-core": ["packages/framework/runtime-core/src/index.ts"],
      "@prisma-next/sql-runtime": ["packages/sql/sql-runtime/src/exports/index.ts"],
      "@prisma-next/sql-runtime/test/utils": ["packages/sql/sql-runtime/test/utils.ts"]
    }
  },
  "references": [
    { "path": "./packages/relational-ir" },
    { "path": "./packages/psl" },
    { "path": "./packages/sql/runtime/drivers/postgres" },
    { "path": "./packages/sql/runtime/adapters/postgres" },
    { "path": "./packages/framework/core-contract" },
    { "path": "./packages/extensions/compat-prisma" },
    { "path": "./packages/schema-emitter" },
    { "path": "./packages/framework/tooling/cli" },
    { "path": "./packages/framework/core-plan" },
    { "path": "./packages/framework/core-operations" },
    { "path": "./packages/framework/authoring/contract-authoring" },
    { "path": "./packages/framework/authoring/contract-ts" },
    { "path": "./packages/framework/authoring/contract-psl" },
    { "path": "./packages/targets/sql/contract-types" },
    { "path": "./packages/sql/contract" },
    { "path": "./packages/sql/operations" },
    { "path": "./packages/targets/sql/emitter" },
    { "path": "./packages/sql/lanes/relational-core" },
    { "path": "./packages/sql/lanes/sql-lane" },
    { "path": "./packages/sql/lanes/orm-lane" },
    { "path": "./packages/sql/authoring/sql-contract-ts" },
    { "path": "./packages/framework/runtime-core" },
    { "path": "./packages/sql/sql-runtime" }
  ]
}
