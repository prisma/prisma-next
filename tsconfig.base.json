{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@prisma-next/adapter-postgres/cli": ["packages/targets/postgres-adapter/src/exports/cli.ts"],
      "@prisma-next/adapter-postgres/runtime": [
        "packages/targets/postgres-adapter/src/exports/runtime.ts"
      ],
      "@prisma-next/adapter-postgres/*": ["packages/targets/postgres-adapter/src/exports/*.ts"],
      "@prisma-next/driver-postgres/cli": ["packages/targets/postgres-driver/src/exports/cli.ts"],
      "@prisma-next/driver-postgres/runtime": [
        "packages/targets/postgres-driver/src/exports/runtime.ts"
      ],
      "@prisma-next/driver-postgres/*": ["packages/targets/postgres-driver/src/exports/*.ts"],
      "@prisma-next/contract": ["packages/framework/core-contract/src/exports/types.ts"],
      "@prisma-next/contract/*": ["packages/framework/core-contract/src/exports/*.ts"],
      "@prisma-next/control-plane": ["packages/framework/core-control-plane/src/exports/types.ts"],
      "@prisma-next/control-plane/types": [
        "packages/framework/core-control-plane/src/exports/types.ts"
      ],
      "@prisma-next/control-plane/executor": [
        "packages/framework/core-control-plane/src/exports/executor.ts"
      ],
      "@prisma-next/control-plane/pack-manifest-types": [
        "packages/framework/core-control-plane/src/pack-manifest-types.ts"
      ],
      "@prisma-next/cli": ["packages/framework/tooling/cli/src/exports/index.ts"],
      "@prisma-next/cli/*": ["packages/framework/tooling/cli/src/exports/*.ts"],
      "@prisma-next/emitter": ["packages/framework/tooling/emitter/src/exports/index.ts"],
      "@prisma-next/emitter/*": ["packages/framework/tooling/emitter/src/exports/*.ts"],
      "@prisma-next/compat-prisma": ["packages/extensions/compat-prisma/src/exports/index.ts"],
      "@prisma-next/compat-prisma/*": ["packages/extensions/compat-prisma/src/exports/*.ts"],
      "@prisma-next/plan": ["packages/framework/core-plan/src/index.ts"],
      "@prisma-next/operations": ["packages/framework/core-operations/src/index.ts"],
      "@prisma-next/core-control-plane/config-types": [
        "packages/framework/core-control-plane/src/exports/config-types.ts"
      ],
      "@prisma-next/core-control-plane/config-validation": [
        "packages/framework/core-control-plane/src/exports/config-validation.ts"
      ],
      "@prisma-next/core-control-plane/emit-contract": [
        "packages/framework/core-control-plane/src/exports/emit-contract.ts"
      ],
      "@prisma-next/core-control-plane/verify-database": [
        "packages/framework/core-control-plane/src/exports/verify-database.ts"
      ],
      "@prisma-next/core-control-plane/errors": [
        "packages/framework/core-control-plane/src/exports/errors.ts"
      ],
      "@prisma-next/core-control-plane/pack-manifest-types": [
        "packages/framework/core-control-plane/src/exports/pack-manifest-types.ts"
      ],
      "@prisma-next/contract-authoring": [
        "packages/framework/authoring/contract-authoring/src/index.ts"
      ],
      "@prisma-next/contract-ts": ["packages/framework/authoring/contract-ts/src/index.ts"],
      "@prisma-next/contract-psl": ["packages/framework/authoring/contract-psl/src/index.ts"],
      "@prisma-next/sql-contract": ["packages/sql/contract/src/index.ts"],
      "@prisma-next/sql-contract/*": ["packages/sql/contract/src/exports/*.ts"],
      "@prisma-next/sql-schema-ir": ["packages/sql/schema-ir/src/index.ts"],
      "@prisma-next/sql-schema-ir/*": ["packages/sql/schema-ir/src/exports/*.ts"],
      "@prisma-next/sql-operations": ["packages/sql/operations/src/index.ts"],
      "@prisma-next/sql-contract-emitter": ["packages/sql/tooling/emitter/src/index.ts"],
      "@prisma-next/family-sql/cli": ["packages/sql/tooling/cli/src/exports/cli.ts"],
      "@prisma-next/family-sql/runtime": ["packages/sql/tooling/cli/src/exports/runtime.ts"],
      "@prisma-next/targets-postgres/cli": ["packages/targets/postgres/src/exports/cli.ts"],
      "@prisma-next/targets-postgres/runtime": ["packages/targets/postgres/src/exports/runtime.ts"],
      "@prisma-next/sql-relational-core": ["packages/sql/lanes/relational-core/src/index.ts"],
      "@prisma-next/sql-relational-core/*": ["packages/sql/lanes/relational-core/src/exports/*.ts"],
      "@prisma-next/sql-lane": ["packages/sql/lanes/sql-lane/src/index.ts"],
      "@prisma-next/sql-lane/*": ["packages/sql/lanes/sql-lane/src/exports/*.ts"],
      "@prisma-next/sql-orm-lane": ["packages/sql/lanes/orm-lane/src/index.ts"],
      "@prisma-next/sql-contract-ts/*": ["packages/sql/authoring/sql-contract-ts/src/exports/*.ts"],
      "@prisma-next/runtime-executor": ["packages/framework/runtime-executor/src/index.ts"],
      "@prisma-next/sql-runtime": ["packages/sql/sql-runtime/src/exports/index.ts"],
      "@prisma-next/sql-runtime/test/utils": ["packages/sql/sql-runtime/test/utils.ts"]
    }
  },
  "references": [
    { "path": "./packages/relational-ir" },
    { "path": "./packages/psl" },
    { "path": "./packages/targets/postgres-driver" },
    { "path": "./packages/targets/postgres-adapter" },
    { "path": "./packages/framework/core-contract" },
    { "path": "./packages/framework/core-control-plane" },
    { "path": "./packages/extensions/compat-prisma" },
    { "path": "./packages/schema-emitter" },
    { "path": "./packages/framework/tooling/cli" },
    { "path": "./packages/framework/core-plan" },
    { "path": "./packages/framework/core-operations" },
    { "path": "./packages/framework/core-control-plane" },
    { "path": "./packages/framework/authoring/contract-authoring" },
    { "path": "./packages/framework/authoring/contract-ts" },
    { "path": "./packages/framework/authoring/contract-psl" },
    { "path": "./packages/sql/contract" },
    { "path": "./packages/sql/schema-ir" },
    { "path": "./packages/sql/operations" },
    { "path": "./packages/sql/tooling/emitter" },
    { "path": "./packages/sql/tooling/cli" },
    { "path": "./packages/targets/postgres" },
    { "path": "./packages/sql/lanes/relational-core" },
    { "path": "./packages/sql/lanes/sql-lane" },
    { "path": "./packages/sql/lanes/orm-lane" },
    { "path": "./packages/sql/authoring/sql-contract-ts" },
    { "path": "./packages/framework/runtime-executor" },
    { "path": "./packages/sql/sql-runtime" }
