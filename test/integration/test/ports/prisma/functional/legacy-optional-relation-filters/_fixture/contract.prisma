// Faithful translation of prisma/prisma functional suite
// `0-legacy-ports/optional-relation-filters`
// (packages/client/tests/functional/0-legacy-ports/optional-relation-filters,
//  postgres matrix entry):
//
//   model User {
//     id    String  @id
//     email String  @unique
//     bio   Bio?
//   }
//
//   model Bio {
//     id     String  @id
//     text   String?
//     user   User?   @relation(fields: [userId], references: [id])
//     userId String? @unique
//   }
//
// Upstream idForProvider(postgresql) is String @id. Ids are seeded explicitly.
model User {
  id    String @id
  email String @unique
  bio   Bio?
}

model Bio {
  id     String  @id @default(cuid(2))
  text   String?
  user   User?   @relation(fields: [userId], references: [id])
  userId String? @unique
}
