// Faithful translation of prisma/prisma functional suite
// `issues/21631-batching-in-transaction` (postgres matrix entry):
//
//   model Worker {
//     id    String @id @default(cuid())
//     email String @unique
//     phone String @unique
//   }
//
// idForProvider(postgresql) is `String @id @default(cuid(2))`.
model Worker {
  id    String @id @default(cuid(2))
  email String @unique
  phone String @unique
}
