// Faithful translation of prisma/prisma functional suite `issues/14954-date-batch`
// (postgres matrix entry):
//
//   model Resource {
//     id   String   @id @default(cuid())
//     date DateTime @unique
//   }
//
// idForProvider(postgresql) is `String @id @default(cuid(2))`.
model Resource {
  id   String   @id @default(cuid(2))
  date DateTime @unique
}
