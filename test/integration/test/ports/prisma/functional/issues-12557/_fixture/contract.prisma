// Faithful translation of prisma/prisma@a6d0155
// packages/client/tests/functional/issues/12557 (postgres matrix entry;
// sqlite/mongodb/cockroachdb/sqlserver opted-out upstream).
//
// Upstream schema (implicit M:N):
//   model Category { id String @id @default(cuid()); name String @unique; brands Brand[] }
//   model Brand { id String @id @default(cuid()); name String @unique; categories Category[] }
//
// prisma-next: implicit M:N must be expressed as an explicit join table.
// Bare list fields on both sides produce a through/N:M relation. The join
// table FKs use onDelete: Cascade to match Prisma's implicit-M:N cascade
// behaviour (deleting a Brand removes its join rows automatically).
// Plain String @id (text, no cuid default) is used so FK columns match; ids
// are seeded explicitly in the test.

model Category {
  id     String   @id
  name   String   @unique
  brands Brand[]
}

model Brand {
  id         String   @id
  name       String   @unique
  categories Category[]
}

model CategoryBrand {
  categoryId String
  brandId    String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@id([categoryId, brandId])
}
