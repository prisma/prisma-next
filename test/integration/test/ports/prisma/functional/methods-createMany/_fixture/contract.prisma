// Faithful translation of prisma/prisma functional suite `methods/createMany`
// (packages/client/tests/functional/methods/createMany, postgres matrix entry):
//
//   model User {
//     id    String  @id @default(cuid())
//     email String  @unique
//     name  String?
//     posts Post[]
//   }
//
//   model Post {
//     id     String @id @default(cuid())
//     title  String
//     user   User   @relation(fields: [userId], references: [id])
//     userId String
//   }

model User {
  id    String  @id @default(cuid(2))
  email String  @unique
  name  String?
  posts Post[]
}

model Post {
  id     String @id @default(cuid(2))
  title  String
  user   User   @relation(fields: [userId], references: [id])
  userId String
}
