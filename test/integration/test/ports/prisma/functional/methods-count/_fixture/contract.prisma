// Faithful translation of prisma/prisma functional suite `methods/count`
// (packages/client/tests/functional/methods/count, postgres matrix entry):
//
//   model User {
//     id    String  @id @default(cuid())
//     email String  @unique
//     age   Int
//     name  String?
//     posts Post[]
//   }
//
//   model Post {
//     id        String   @id @default(cuid())
//     createdAt DateTime @default(now())
//     updatedAt DateTime @updatedAt
//     published Boolean
//     title     String
//     content   String?
//     authorId  String
//     author    User?    @relation(fields: [authorId], references: [id])
//   }

model User {
  id    String  @id @default(cuid(2))
  email String  @unique
  age   Int
  name  String?
  posts Post[]
}

model Post {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now())
  updatedAt temporal.updatedAt()
  published Boolean
  title     String
  content   String?
  authorId  String
  author    User?    @relation(fields: [authorId], references: [id])
}
