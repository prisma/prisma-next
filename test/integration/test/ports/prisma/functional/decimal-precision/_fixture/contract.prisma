// Faithful translation of prisma/prisma functional suite `decimal/precision`
// (packages/client/tests/functional/decimal/precision).
//
// Upstream matrix (postgres-applicable rows): a TestModel whose single
// `decimal Decimal @db.Decimal(precision, scale)` field is materialised at
// (10,0), (20,10) and (38,30). prisma-next PSL carries fixed precision/scale
// through a named type with `@db.Numeric(p, s)`, so one column per tested
// precision reproduces the exact storage constraint under test.
// (The (65,30) and (1000,500) matrix rows exceed postgres numeric limits and
// are excluded for postgres upstream.)
types {
  Decimal10_0  = Decimal @db.Numeric(10, 0)
  Decimal20_10 = Decimal @db.Numeric(20, 10)
  Decimal38_30 = Decimal @db.Numeric(38, 30)
}

model TestModel {
  id     String        @id @default(cuid(2))
  d10_0  Decimal10_0?
  d20_10 Decimal20_10?
  d38_30 Decimal38_30?
}
