// Faithful translation of prisma/prisma functional suite
// `issues/29174-jsonb-parameter-regression` (postgres matrix entry):
//
//   model User {
//     id         String @id @default(cuid())
//     properties Json
//   }
//
// idForProvider(postgresql) is `String @id @default(cuid(2))`.
model User {
  id         String @id @default(cuid(2))
  properties Json
}
