// Faithful translation of prisma/prisma@a6d0155
// packages/client/tests/functional/multi-schema (postgres matrix entry, mapTable = false).
//
// Upstream schema (postgres, no @@map):
//
//   datasource db { provider = "postgresql"; schemas = ["base", "transactional"] }
//
//   model User {
//     id       String  @id @default(cuid())
//     email    String
//     posts    Post[]
//     @@schema("base")
//   }
//
//   model Post {
//     id       String  @id @default(cuid())
//     title    String
//     authorId String
//     author   User?   @relation(fields: [authorId], references: [id])
//     @@schema("transactional")
//   }
//
// prisma-next maps @@schema("base") -> namespace base { model User {} }
// and @@schema("transactional") -> namespace transactional { model Post {} }.
// Cross-namespace relation: user base.User @relation(...).

namespace base {
  model User {
    id       String  @id @default(cuid(2))
    email    String
    posts    transactional.Post[]
  }
}

namespace transactional {
  model Post {
    id       String  @id @default(cuid(2))
    title    String
    authorId String
    author   base.User? @relation(fields: [authorId], references: [id])
  }
}
