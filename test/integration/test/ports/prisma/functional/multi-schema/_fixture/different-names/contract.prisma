namespace base {
  model User {
    id       String  @id @default(cuid(2))
    email    String
    posts    transactional.Post[]

    @@map("some_table_user")
  }
}

namespace transactional {
  model Post {
    id       String  @id @default(cuid(2))
    title    String
    authorId String
    author   base.User? @relation(fields: [authorId], references: [id])

    @@map("some_table_post")
