// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`db introspect command (e2e) > --dry-run: outputs tree structure without writing file 1`] = `
"prisma-next db introspect → Inspect the database schema and generate PSL
│ config:               prisma-next.config.ts
│ database:             postgres://****:****@127.0.0.1:XXXXX/template1?sslmode=disable
│ Read more             https://pris.ly/db-introspect
└

│  contract
│  ├─ table post
│  │  ├─ columns
│  │  │  ├─ id: int4 (not nullable)
│  │  │  ├─ title: text (not nullable)
│  │  │  └─ userId: int4 (nullable)
│  │  └─ primary key: id
│  ├─ table user
│  │  ├─ columns
│  │  │  ├─ id: int4 (not nullable)
│  │  │  ├─ email: text (not nullable)
│  │  │  └─ name: text (nullable)
│  │  ├─ primary key: id
│  │  └─ unique index user_email_unique
│  └─ plpgsql dependency is installed"
`;

exports[`db introspect command (e2e) > --json includes psl.path when file was written 1`] = `
{
  "meta": {
    "configPath": "prisma-next.config.ts",
    "dbUrl": "postgres://****:****@127.0.0.1:XXXXX/template1?sslmode=disable",
  },
  "ok": true,
  "psl": {
    "path": "output/schema.prisma",
  },
  "schema": {
    "annotations": {
      "pg": {
        "schema": "public",
        "version": "17.5",
      },
    },
    "dependencies": [
      {
        "id": "postgres.extension.plpgsql",
      },
    ],
    "tables": {
      "user": {
        "columns": {
          "email": {
            "name": "email",
            "nativeType": "text",
            "nullable": false,
          },
          "id": {
            "default": "nextval('user_id_seq'::regclass)",
            "name": "id",
            "nativeType": "int4",
            "nullable": false,
          },
        },
        "foreignKeys": [],
        "indexes": [],
        "name": "user",
        "primaryKey": {
          "columns": [
            "id",
          ],
          "name": "user_pkey",
        },
        "uniques": [],
      },
    },
  },
  "summary": "Schema introspected successfully",
  "target": {
    "familyId": "sql",
    "id": "postgres",
  },
  "timings": {
    "total": 0,
  },
}
`;
