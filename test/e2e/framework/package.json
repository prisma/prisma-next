{
  "name": "@prisma-next/e2e-tests",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "biome check . --config-path ../../../biome.json --error-on-warnings",
    "lint:fix": "biome check --write . --config-path ../../../biome.json",
    "lint:fix:unsafe": "biome check --write --unsafe . --config-path ../../../biome.json",
    "emit": "prisma-next emit",
    "clean": "node ../../../scripts/clean.mjs"
  },
  "devDependencies": {
    "vitest": "^2.1.1",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "@types/node": "^20.11.30",
    "@types/pg": "^8.11.10",
    "pg": "^8.11.5"
  },
  "dependencies": {
    "@prisma-next/cli": "workspace:*",
    "@prisma-next/integration-tests": "workspace:*",
    "@prisma-next/sql-contract": "workspace:*",
    "@prisma-next/sql-contract-ts": "workspace:*",
    "@prisma-next/sql-runtime": "workspace:*",
    "@prisma-next/sql-relational-core": "workspace:*",
    "@prisma-next/sql-lane": "workspace:*",
    "@prisma-next/adapter-postgres": "workspace:*",
    "@prisma-next/driver-postgres": "workspace:*",
    "@prisma-next/family-sql": "workspace:*",
    "@prisma-next/target-postgres": "workspace:*",
    "@prisma-next/test-utils": "workspace:*"
  }
}
