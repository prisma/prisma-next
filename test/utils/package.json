{
  "name": "@prisma-next/test-utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check . --config-path ../../biome.json --error-on-warnings",
    "lint:fix": "biome check --write . --config-path ../../biome.json",
    "lint:fix:unsafe": "biome check --write --unsafe . --config-path ../../biome.json",
    "clean": "node ../../scripts/clean.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@prisma/dev": "catalog:",
    "get-port": "^7.1.0",
    "pg": "^8.11.5",
    "@types/pg": "^8.11.10",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.1"
  },
  "exports": {
    ".": {
      "types": "./dist/exports/index.d.ts",
      "import": "./dist/exports/index.js"
    },
    "./column-descriptors": {
      "types": "./dist/exports/column-descriptors.d.ts",
      "import": "./dist/exports/column-descriptors.js"
    },
    "./operation-descriptors": {
      "types": "./dist/exports/operation-descriptors.d.ts",
      "import": "./dist/exports/operation-descriptors.js"
    },
    "./timeouts": {
      "types": "./dist/exports/timeouts.d.ts",
      "import": "./dist/exports/timeouts.js"
    },
    "./typed-expectations": {
      "types": "./dist/exports/typed-expectations.d.ts",
      "import": "./dist/exports/typed-expectations.js"
    }
  }
}
