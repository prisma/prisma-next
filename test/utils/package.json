{
  "name": "@prisma-next/test-utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "lint": "biome check . --error-on-warnings",
    "lint:fix": "biome check --write .",
    "lint:fix:unsafe": "biome check --write --unsafe .",
    "clean": "rm -rf dist coverage .tmp-output"
  },
  "devDependencies": {
    "@prisma-next/tsconfig": "workspace:*",
    "@prisma-next/tsdown": "workspace:*",
    "@prisma/dev": "catalog:",
    "@types/pg": "catalog:",
    "pg": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "exports": {
    "./column-descriptors": "./src/column-descriptors.ts",
    ".": "./src/exports/index.ts",
    "./operation-descriptors": "./src/operation-descriptors.ts",
    "./timeouts": "./src/timeouts.ts",
    "./typed-expectations": "./src/typed-expectations.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      "./column-descriptors": "./dist/column-descriptors.mjs",
      ".": "./dist/exports/index.mjs",
      "./operation-descriptors": "./dist/operation-descriptors.mjs",
      "./timeouts": "./dist/timeouts.mjs",
      "./typed-expectations": "./dist/typed-expectations.mjs",
      "./package.json": "./package.json"
    }
  }
}
